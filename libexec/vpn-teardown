#!/bin/sh
# vpn-teardown -- cleanly stop the openconnect-auto-sso tunnel (privileged helper).
#
# install-autostart.sh copies this to a ROOT-OWNED path
# (/usr/local/libexec/openconnect-auto-sso/vpn-teardown, root:wheel 0755) and grants
# it a scoped NOPASSWD sudoers rule, so the user-domain connect script can trigger a
# clean disconnect on logout/uninstall WITHOUT being able to run arbitrary code as
# root (unlike NOPASSWD on openconnect itself). For that boundary to hold this helper
# must stay SELF-CONTAINED: it reads only a root-owned pidfile and never sources or
# executes any user-writable file.
#
# openconnect runs as root and, on SIGTERM, runs its disconnect vpnc-script pass
# (restoring routes/DNS, removing /etc/resolver files, stopping dnsroute). We send
# that signal to the recorded PID and wait for it to finish.
set -eu

# Must match lib/common.sh VPNPID_FILE (hardcoded here because a root helper must
# not source the user-writable lib/common.sh).
PIDFILE=/var/run/openconnect-auto-sso.vpnpid

[ -f "$PIDFILE" ] || exit 0                       # not connected: nothing to do
pid=$(cat "$PIDFILE" 2>/dev/null || true)
case "$pid" in
    '' | *[!0-9]*) rm -f "$PIDFILE" 2>/dev/null || true; exit 0 ;;   # empty/garbage
esac

# Verify the PID really is openconnect before signalling it -- a recycled PID could
# belong to an unrelated process, and we run as root.
comm=$(ps -p "$pid" -o comm= 2>/dev/null || true)
case "$comm" in
    *openconnect*) ;;
    *) rm -f "$PIDFILE" 2>/dev/null || true; exit 0 ;;              # stale pidfile
esac

kill -TERM "$pid" 2>/dev/null || true
# Wait (up to ~10s) for openconnect's disconnect pass to complete and exit.
_i=0
while kill -0 "$pid" 2>/dev/null && [ "$_i" -lt 100 ]; do
    sleep 0.1; _i=$((_i + 1))
done
rm -f "$PIDFILE" 2>/dev/null || true

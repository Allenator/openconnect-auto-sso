#!/bin/sh
# vpn-teardown -- cleanly stop the openconnect-auto-sso tunnel (privileged helper).
#
# install-autostart.sh copies this to a ROOT-OWNED path
# (/usr/local/libexec/openconnect-auto-sso/vpn-teardown, root:wheel 0755) and grants
# it a scoped NOPASSWD sudoers rule, so the user-domain connect script can trigger a
# clean disconnect / heal stale state WITHOUT being able to run arbitrary code as
# root (unlike NOPASSWD on openconnect itself). For that boundary to hold this helper
# must stay SELF-CONTAINED: it reads only root-owned/OS state and never sources or
# executes any user-writable file, and it only ever removes files that carry our
# own marker.
#
# Modes:
#   (default)   stop the running tunnel: SIGTERM the recorded openconnect PID so it
#               runs its own disconnect vpnc-script pass (restore routes/DNS, remove
#               /etc/resolver files, stop dnsroute), then wait for it to exit.
#   --sweep     heal after a crash/hard-kill that skipped that disconnect pass:
#               remove our leftover /etc/resolver files so a stale one can't block
#               the next connect's DNS. No-op if a tunnel is currently up.
set -eu

# Must match lib/common.sh VPNPID_FILE and RESOLVER_MARKER (hardcoded here because a
# root helper must not source the user-writable lib/common.sh).
PIDFILE=/var/run/openconnect-auto-sso.vpnpid
MARKER='# openconnect-auto-sso'

do_sweep() {
    # Only when nothing is connected -- never yank a live tunnel's resolver files.
    pgrep -x openconnect >/dev/null 2>&1 && return 0
    for _rf in /etc/resolver/*; do
        [ -f "$_rf" ] || continue
        IFS= read -r _first < "$_rf" 2>/dev/null || continue
        [ "$_first" = "$MARKER" ] && rm -f "$_rf" 2>/dev/null || true
    done
}

case "${1:-}" in
    --sweep) do_sweep; exit 0 ;;
    '')      ;;                              # default: stop the tunnel
    *)       echo "usage: vpn-teardown [--sweep]" >&2; exit 2 ;;
esac

[ -f "$PIDFILE" ] || exit 0                       # not connected: nothing to do
pid=$(cat "$PIDFILE" 2>/dev/null || true)
case "$pid" in
    '' | *[!0-9]*) rm -f "$PIDFILE" 2>/dev/null || true; exit 0 ;;   # empty/garbage
esac

# Verify the PID really is openconnect before signalling it -- a recycled PID could
# belong to an unrelated process, and we run as root.
comm=$(ps -p "$pid" -o comm= 2>/dev/null || true)
case "$comm" in
    *openconnect*) ;;
    *) rm -f "$PIDFILE" 2>/dev/null || true; exit 0 ;;              # stale pidfile
esac

kill -TERM "$pid" 2>/dev/null || true
# Wait (up to ~10s) for openconnect's disconnect pass to complete and exit.
_i=0
while kill -0 "$pid" 2>/dev/null && [ "$_i" -lt 100 ]; do
    sleep 0.1; _i=$((_i + 1))
done
rm -f "$PIDFILE" 2>/dev/null || true

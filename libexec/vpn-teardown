#!/bin/sh
# vpn-teardown -- cleanly stop the openconnect-auto-sso tunnel (privileged helper).
#
# install-autostart.sh copies this to a ROOT-OWNED path
# (/usr/local/libexec/openconnect-auto-sso/vpn-teardown, root:wheel 0755) and grants
# it a scoped NOPASSWD sudoers rule, so the user-domain connect script can trigger a
# clean disconnect / heal stale state WITHOUT being able to run arbitrary code as
# root (unlike NOPASSWD on openconnect itself). For that boundary to hold this helper
# must stay SELF-CONTAINED: it reads only OS state and never sources or executes any
# user-writable file, and it only ever removes files that carry our own marker.
#
# Modes:
#   (default)   stop the running tunnel: SIGTERM every openconnect so it runs its own
#               disconnect vpnc-script pass (restore routes/DNS, remove /etc/resolver
#               files, stop dnsroute), then wait for it to exit. openconnect is found
#               by name (`pgrep -x openconnect` -- the same notion the sweeps use), so
#               this works for split AND full tunnels and every openconnect version,
#               with no pidfile to write or trust. NOTE: this signals ANY openconnect;
#               a second unrelated openconnect VPN would also get a clean disconnect.
#   --sweep     heal after a crash/hard-kill that skipped that disconnect pass: remove
#               our leftover /etc/resolver files so a stale one can't block the next
#               connect. No-op if a tunnel is up.
set -eu

# Must match lib/common.sh RESOLVER_MARKER (hardcoded here because a root helper must
# not source the user-writable lib/common.sh).
MARKER='# openconnect-auto-sso'

do_sweep() {
    # Only when nothing is connected -- never yank a live tunnel's resolver files.
    pgrep -x openconnect >/dev/null 2>&1 && return 0
    for _rf in /etc/resolver/*; do
        [ -f "$_rf" ] || continue
        # grep -qxF (any line, tolerant of a missing trailing newline) -- matches the
        # other two sweepers in the connect script and the wrapper.
        grep -qxF -- "$MARKER" "$_rf" 2>/dev/null && rm -f "$_rf" 2>/dev/null || true
    done
}

case "${1:-}" in
    --sweep) do_sweep; exit 0 ;;
    '')      ;;                              # default: stop the tunnel
    *)       echo "usage: vpn-teardown [--sweep]" >&2; exit 2 ;;
esac

_pids=$(pgrep -x openconnect 2>/dev/null || true)
[ -n "$_pids" ] || exit 0                    # not connected: nothing to do
# shellcheck disable=SC2086  # intentional word-split into individual PIDs
kill -TERM $_pids 2>/dev/null || true
# Wait (up to ~10s total) for each signaled openconnect's disconnect pass to finish.
_i=0
for _p in $_pids; do
    while kill -0 "$_p" 2>/dev/null && [ "$_i" -lt 100 ]; do
        sleep 0.1; _i=$((_i + 1))
    done
done

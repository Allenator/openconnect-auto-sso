#!/bin/sh
# Launch the persistent-profile SSO browser from the project's venv.
# openconnect --external-browser invokes this with the login URL as $1.
#
# Resolves its own real path first, so it works when symlinked into ~/.local/bin.
src=$0
_n=0
while [ -L "$src" ]; do
    _n=$((_n + 1))
    [ "$_n" -gt 40 ] && { echo "vpn-browser: too many symlink levels resolving $0" >&2; exit 1; }
    dir=$(cd "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case $src in
        /*) ;;
        *) src=$dir/$src ;;
    esac
done
proj=$(cd "$(dirname "$src")/.." && pwd)

# Run the venv python DIRECTLY rather than `uv run`: openconnect spawns this deep inside
# Phase 1, so it must not depend on `uv` being on PATH (a missing uv would exec-fail 127
# and wedge auth) nor trigger uv's implicit sync (network / .venv mutation) mid-connect.
# Matches bin/openconnect-auto-sso's convention.
PY="$proj/.venv/bin/python"; [ -x "$PY" ] || PY=python3
exec "$PY" "$proj/src/vpn_browser.py" "$@"

#!/bin/sh
# openconnect-auto-sso — connect to a browser-SSO VPN in two phases so the
# login browser never runs as root:
#   Phase 1 (as you):   openconnect --authenticate --external-browser=<helper>
#                       -> prints COOKIE / CONNECT_URL / FINGERPRINT / RESOLVE
#   Phase 2 (sudo):     openconnect --cookie-on-stdin ...  (no browser)
#
# All site-specifics come from a TOML config (see config.example.toml).
set -eu

# --- locate the project (works when symlinked into ~/.local/bin) -------------
src=$0
while [ -L "$src" ]; do
    dir=$(cd "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case $src in /*) ;; *) src=$dir/$src ;; esac
done
PROJ=$(cd "$(dirname "$src")/.." && pwd)
. "$PROJ/lib/common.sh"   # RESOLVER_MARKER, TEARDOWN_BIN, and the recovery timing +
                          # helpers (wait_for_server, RECONNECT_TIMEOUT_*, NET_WAIT_MAX)

# --- load configuration ------------------------------------------------------
# Precedence: $OC_AUTO_SSO_CONFIG, then the standard external location
# ~/.config/openconnect-auto-sso/config.toml, then an in-repo config.toml (dev only).
XDG_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/openconnect-auto-sso/config.toml"
if [ -n "${OC_AUTO_SSO_CONFIG:-}" ]; then
    CONFIG="$OC_AUTO_SSO_CONFIG"
elif [ -f "$XDG_CONFIG" ]; then
    CONFIG="$XDG_CONFIG"
elif [ -f "$PROJ/config.toml" ]; then
    CONFIG="$PROJ/config.toml"
else
    CONFIG="$XDG_CONFIG"
fi
if [ ! -f "$CONFIG" ]; then
    echo "error: no config found (expected $XDG_CONFIG)" >&2
    echo "       mkdir -p \"$(dirname "$XDG_CONFIG")\" && cp \"$PROJ/config.example.toml\" \"$XDG_CONFIG\"   # then edit server" >&2
    exit 1
fi
# Parse the TOML config into shell variables. The parser validates and shell-quotes
# each value; the config is never sourced, so it cannot execute code or inject shell.
PY="$PROJ/.venv/bin/python"; [ -x "$PY" ] || PY=python3
_conf=$("$PY" "$PROJ/src/loadconfig.py" "$CONFIG") || exit 1
eval "$_conf"

: "${SERVER:?server is required in the config}"
PROTOCOL="${PROTOCOL:-}"
SPLIT_ROUTES="${SPLIT_ROUTES:-}"
PROFILE_NAME="${PROFILE_NAME:-openconnect-auto-sso}"
CALLBACK="${CALLBACK:-localhost:29786}"
KEEPALIVE_HOST="${KEEPALIVE_HOST:-}"
KEEPALIVE_INTERVAL="${KEEPALIVE_INTERVAL:-30}"
# How long openconnect retries in-process before giving up and exiting. The right value
# depends on whether anything will restart us (see lib/common.sh): under launchd, give up
# fast so KeepAlive can start a FRESH connect -- the only thing that works after a sleep.
# In a terminal nothing would respawn us, so keep openconnect's own long budget instead.
# An explicit `reconnect_timeout` in the config always wins.
if [ -z "${RECONNECT_TIMEOUT:-}" ]; then
    if [ -t 0 ]; then
        RECONNECT_TIMEOUT="$RECONNECT_TIMEOUT_INTERACTIVE"
    else
        RECONNECT_TIMEOUT="$RECONNECT_TIMEOUT_SUPERVISED"
    fi
fi
ALLOW_INCOMING="${ALLOW_INCOMING:-0}"
PROXY_NAMES="${PROXY_NAMES:-}"          # DNS names routed via the VPN (proxy + /etc/resolver)
ROUTE_INTERNAL="${ROUTE_INTERNAL:-0}"   # also route the VPN's own subnet (server-pushed)
ROUTE_SPLITS="${ROUTE_SPLITS:-0}"       # also add the server's split-include subnets
PROXY_PORT="${PROXY_PORT:-45353}"       # loopback port for the DNS-routing proxy
KA_DNS_FILE="${TMPDIR:-/tmp}/openconnect-auto-sso.dns.$$"     # keepalive @dns target
# The proxy PID file drives a ROOT kill in the wrapper (it SIGTERMs the pid it holds),
# so it lives in /var/run (root:daemon, 0775): a user-writable TMPDIR path would let the
# tunnel's own user seed a victim PID for root to signal, and the invoking user is not in
# group daemon so cannot write here. Only the wrapper (root) reads and writes it.
PROXY_PIDFILE="/var/run/openconnect-auto-sso.proxy.$$"       # DNS-routing proxy PID

# The SSO browser helper (spawned by openconnect) reads these from the env.
export PROFILE_NAME CALLBACK

# --- startup guards for leftovers from failed teardowns ----------------------
# Shared prompt tail: on a tty, ask QUESTION (default answer DEFAULT) and run
# FIX_FN on yes; if the fix didn't run (no tty, declined, failed), print the
# manual LATER_HINT. Always returns 0.
#   _offer_sudo_fix QUESTION DEFAULT(y|n) LATER_HINT FIX_FN
_offer_sudo_fix() {
    _q=$1; _def=$2; _later=$3; _fn=$4
    _fixed=n
    if [ -t 0 ]; then
        [ "$_def" = y ] && _yn='[Y/n]' || _yn='[y/N]'
        printf "  %s (needs sudo)? %s " "$_q" "$_yn" >&2
        read -r _ans || _ans=$_def
        case "$_ans" in [yY]*) _do=y ;; [nN]*) _do=n ;; *) _do=$_def ;; esac
        [ "$_do" = y ] && "$_fn" && _fixed=y || true
    fi
    [ "$_fixed" = y ] || echo "  Clean later:  $_later" >&2
}

# vpn-slice's "block incoming" firewall appends an anchor to /etc/pf.conf and can
# fail to remove it on teardown. The leftover reloads on every boot and keeps
# iCloud Private Relay disabled even with no VPN connected. Warn (and offer to fix).
_fix_pf_anchor() {
    if sudo cp /etc/pf.conf /etc/pf.conf.bak &&
       sudo sed -i '' '/anchor "vpn_slice/d' /etc/pf.conf &&
       sudo pfctl -f /etc/pf.conf 2>/dev/null; then
        echo "  cleaned (backup at /etc/pf.conf.bak)." >&2
    else
        echo "  cleanup failed; remove the line manually." >&2
        return 1
    fi
}
if [ -r /etc/pf.conf ] && grep -q 'anchor "vpn_slice' /etc/pf.conf 2>/dev/null; then
    echo "WARNING: leftover vpn-slice firewall anchor in /etc/pf.conf:" >&2
    grep -n 'anchor "vpn_slice' /etc/pf.conf | sed 's/^/    /' >&2
    echo "  It persists across reboots and can keep iCloud Private Relay off even" >&2
    echo "  with no VPN connected (a vpn-slice teardown bug)." >&2
    _offer_sudo_fix "Remove it now" n \
        "sudo sed -i '' '/anchor \"vpn_slice/d' /etc/pf.conf && sudo pfctl -f /etc/pf.conf" \
        _fix_pf_anchor
fi

# Our resolver files (first line: $RESOLVER_MARKER) point domains at the loopback
# DNS proxy; if a teardown was missed they outlive the proxy and break every
# lookup under those domains -- including Phase 1's resolution of $SERVER when it
# sits under one of them. The marker guarantees we only touch our own.
_rm_resolver_leftovers() {
    # $_leftover intentionally word-splits into the individual paths; `set -f`
    # (in a subshell, so it doesn't leak) stops those paths being re-globbed --
    # a resolver filename could contain a shell glob metacharacter.
    ( set -f; sudo rm -f $_leftover ) && echo "  removed." >&2
}
_leftover=""
for _f in /etc/resolver/*; do
    [ -f "$_f" ] || continue
    grep -qxF -- "$RESOLVER_MARKER" "$_f" 2>/dev/null && _leftover="$_leftover $_f" || true
done
if [ -n "$_leftover" ]; then
    if pgrep -x openconnect >/dev/null 2>&1; then
        echo "WARNING: an openconnect is already running; leaving its resolver files:$_leftover" >&2
    else
        echo "WARNING: leftover DNS resolver files from an earlier session:" >&2
        for _f in $_leftover; do echo "    $_f" >&2; done
        echo "  They point those domains at a proxy that is no longer running, so" >&2
        echo "  lookups under them fail -- and can break this connect." >&2
        if [ ! -t 0 ] && [ -x "$TEARDOWN_BIN" ]; then
            # Non-interactive (e.g. under the LaunchAgent): can't prompt, and this
            # user-domain sweep can't sudo-rm root-owned files. Delegate to the
            # root-owned teardown helper (scoped NOPASSWD) to heal them.
            sudo -n "$TEARDOWN_BIN" --sweep 2>/dev/null && echo "  swept via teardown helper." >&2 \
                || echo "  Clean later:  sudo rm$_leftover" >&2
        else
            # Default Yes (unlike the pf guard): the marker proves they're ours, no
            # openconnect is running, and keeping them breaks DNS machine-wide.
            _offer_sudo_fix "Remove them now" y "sudo rm$_leftover" _rm_resolver_leftovers
        fi
    fi
fi

# Resolve openconnect to an absolute path and use it for BOTH phases. Phase 2 runs
# it via sudo; passing the absolute path makes the NOPASSWD sudoers drop-in from
# install-autostart.sh (which pins openconnect's absolute path) match
# deterministically -- independent of sudo's secure_path / the invoking PATH, which
# a bare `sudo openconnect` would depend on.
OPENCONNECT=$(command -v openconnect || true)
[ -n "$OPENCONNECT" ] || { echo "error: openconnect not found on PATH" >&2; exit 1; }

# A wake from sleep -- or a login before Wi-Fi associates -- can leave us with no usable
# network yet. Authenticating into that fails instantly and exits non-zero, and under
# launchd that burns a throttled retry (respawn is delayed by THROTTLE_INTERVAL minus our
# runtime). So WAIT for the server to actually be reachable instead: staying alive is
# always cheaper than exiting into the throttle. wait_for_server lives in lib/common.sh,
# which owns the sizing (NET_WAIT_MAX >= THROTTLE_INTERVAL, so an eventual give-up still
# respawns immediately). A terminal user has no supervisor and wants a prompt error rather
# than a multi-minute hang, so shorten the bound there.
if [ -t 0 ]; then
    NET_WAIT_MAX=10
fi
# Bounded, and best-effort: on timeout we fall through and let Phase 1 report the real error.
wait_for_server "$SERVER" || true

# --- Phase 1: authenticate as the current user (no sudo, no root browser) ----
echo ">> authenticating to $SERVER" >&2
authenticate() {
    if [ -n "$PROTOCOL" ]; then
        "$OPENCONNECT" --protocol="$PROTOCOL" \
            --external-browser="$PROJ/bin/vpn-browser" --authenticate "$SERVER"
    else
        "$OPENCONNECT" \
            --external-browser="$PROJ/bin/vpn-browser" --authenticate "$SERVER"
    fi
}

COOKIE=''; HOST=''; CONNECT_URL=''; FINGERPRINT=''; RESOLVE=''

# If the user aborts (Ctrl-C) while authentication is still in progress, end the
# SSO browser so it isn't left orphaned (the script would otherwise exit before
# the post-auth pkill below).
trap 'pkill -f "$PROJ/src/vpn_browser.py" 2>/dev/null; exit 130' INT TERM

auth_out=$(authenticate) || { echo "error: authentication failed" >&2; exit 1; }

# Phase 1 done, so the SSO browser is no longer needed. Some servers complete the
# SSO server-side (no localhost callback), so the helper cannot self-close -- end
# it here. (It flushes cookies to disk every few seconds, so nothing is lost.)
pkill -f "$PROJ/src/vpn_browser.py" 2>/dev/null || true

# Phase 2 signal handling. In a terminal, Ctrl-C reaches the root openconnect child
# directly via the foreground process group, so we clear our trap and let openconnect
# run its own clean disconnect. Under launchd there is no controlling tty, so the
# signal reaches only this (user) script and not the root child -- so invoke the
# privileged teardown helper (installed root-owned + scoped-NOPASSWD by
# install-autostart.sh) to SIGTERM openconnect for a clean disconnect. `sudo -n`
# never prompts: if the helper/rule isn't present it fails fast and we just exit.
# Test stdin (matches the startup sweep's `[ ! -t 0 ]`), so a manual run with only
# stderr redirected still takes the terminal path.
if [ -t 0 ]; then
    trap - INT TERM
else
    trap '[ -x "$TEARDOWN_BIN" ] && sudo -n "$TEARDOWN_BIN" 2>/dev/null; exit 143' INT TERM
fi

eval "$auth_out"   # sets COOKIE / HOST / CONNECT_URL / FINGERPRINT / RESOLVE

if [ -z "$COOKIE" ]; then
    echo "error: no session cookie (login cancelled, or server has no SSO)" >&2
    exit 1
fi

# --- Phase 2: build the tunnel as root (no browser involved) -----------------
# NOTE: deliberately NO --setuid. On macOS, dropping privileges makes openconnect
# run the DISCONNECT vpnc-script as the unprivileged user, which then cannot
# restore routes or DNS -- leaving the machine with no default route and stale VPN
# DNS servers after you disconnect. Staying root for the tunnel's lifetime lets
# teardown cleanly undo everything.
set -- --cookie-on-stdin --servercert "$FINGERPRINT"
[ -n "$RESOLVE" ] && set -- "$@" --resolve "$RESOLVE"
[ -n "$PROTOCOL" ] && set -- "$@" --protocol="$PROTOCOL"
# Budget for openconnect's own in-process reconnect; sized by supervisor presence above.
# lib/common.sh owns the rationale (why a sleep needs a FRESH connect, not a reconnect).
set -- "$@" --reconnect-timeout="$RECONNECT_TIMEOUT"
# _shq: emit $1 as a safely single-quoted shell word (embedded ' -> '\''), so a
# space or apostrophe in a path survives openconnect re-parsing the -s string via sh.
_shq() { printf "'"; printf '%s' "$1" | sed "s/'/'\\\\''/g"; printf "'"; }
if [ -n "$SPLIT_ROUTES$PROXY_NAMES" ] || [ "$ROUTE_INTERNAL" = "1" ] || [ "$ROUTE_SPLITS" = "1" ]; then
    # root's PATH usually excludes Homebrew, so resolve vpn-slice to an abs path.
    VPN_SLICE=$(command -v vpn-slice || true)
    [ -n "$VPN_SLICE" ] || { echo "error: split/DNS options set but vpn-slice not found" >&2; exit 1; }
    # Name-based routing starts src/dnsroute.py (needs the venv + dnspython) as root
    # inside the wrapper, where a failure would be silent. Pre-flight it here, in the
    # user domain, so a broken install fails loudly BEFORE we bring the tunnel up.
    if [ -n "$PROXY_NAMES" ]; then
        if [ ! -x "$PROJ/.venv/bin/python" ] || \
           ! "$PROJ/.venv/bin/python" -c 'import dns.message' 2>/dev/null; then
            echo "error: DNS-routing (a name in via_vpn) needs the bundled venv with" >&2
            echo "       dnspython at $PROJ/.venv -- run 'uv sync' in the repo." >&2
            exit 1
        fi
    fi
    # Route through the vpnc-slice wrapper so the DNS-routing proxy and the @server
    # token can use the VPN's pushed CISCO_SPLIT_DNS/CISCO_DEF_DOMAIN/INTERNAL_IP4_DNS
    # (sudo strips our env, so the wrapper's config is baked into this -s string).
    # openconnect runs this whole -s string via `/bin/sh -c`, which re-splits it on
    # spaces, so PATH-valued fields are single-quoted (_shq) to survive a space -- or
    # an apostrophe -- in $PROJ or $TMPDIR. The unquoted fields (PROXY_NAMES/
    # PROXY_PORT/SPLIT_ROUTES) are validated by loadconfig to contain no spaces or
    # shell metacharacters.
    vs="$(_shq "$PROJ/bin/vpnc-slice")"
    [ -n "${OC_DUMP:-}" ] && vs="$vs --dump-env $(_shq "$OC_DUMP")"        # diagnostic env dump
    [ "$KEEPALIVE_HOST" = "@dns" ] && vs="$vs --write-dns $(_shq "$KA_DNS_FILE")"  # keepalive target
    # DNS-driven auto-routing: resolve these names via the VPN's DNS and route each
    # answered IP through the tunnel (handled by the wrapper + src/dnsroute.py).
    [ -n "$PROXY_NAMES" ] && vs="$vs --proxy $PROXY_NAMES $PROXY_PORT $(_shq "$PROXY_PIDFILE")"
    vs="$vs $(_shq "$VPN_SLICE")"
    # ALLOW_INCOMING=1 drops vpn-slice's pf firewall (keeps iCloud Private Relay working).
    [ "$ALLOW_INCOMING" = "1" ] && vs="$vs -i"
    # Dynamic routes pushed by the VPN (no need to hardcode them):
    [ "$ROUTE_INTERNAL" = "1" ] && vs="$vs -I"        # VPN's own subnet
    [ "$ROUTE_SPLITS" = "1" ] && vs="$vs -S"          # server split-includes
    [ -n "$SPLIT_ROUTES" ] && vs="$vs $SPLIT_ROUTES"  # your explicit subnets
    set -- "$@" -s "$vs"
fi
# Full tunnel (no split/DNS options) needs no -s: openconnect uses its own default
# vpnc-script. Clean teardown still works -- vpn-teardown finds openconnect by name.

# Optional keepalive: some servers drop an idle tunnel. Ping a host *inside* the
# VPN periodically so a little traffic keeps flowing. The subshell watches the
# script's PID and stops when we exit (belt-and-suspenders with the EXIT trap).
if [ -n "$KEEPALIVE_HOST" ]; then
    if [ "$KEEPALIVE_HOST" = "@dns" ]; then
        rm -f "$KA_DNS_FILE"   # the wrapper writes the VPN's pushed DNS server here
        echo ">> keepalive: ping the VPN's DNS server every ${KEEPALIVE_INTERVAL}s" >&2
    else
        echo ">> keepalive: ping $KEEPALIVE_HOST every ${KEEPALIVE_INTERVAL}s" >&2
    fi
    ( while kill -0 "$$" 2>/dev/null; do
          if [ "$KEEPALIVE_HOST" = "@dns" ]; then
              host=$(cat "$KA_DNS_FILE" 2>/dev/null || true)
          else
              host="$KEEPALIVE_HOST"
          fi
          [ -n "$host" ] && ping -c 1 -t 5 "$host" >/dev/null 2>&1 || true
          sleep "$KEEPALIVE_INTERVAL"
      done ) &
    KA_PID=$!
fi

# Clean up on exit: stop the keepalive pinger and remove the keepalive temp file. The
# DNS-routing proxy and its pidfile are owned by ROOT (the wrapper starts the proxy and
# writes the pidfile under /var/run), so this unprivileged trap can neither signal the
# proxy nor unlink the pidfile -- both are left to the wrapper's disconnect pass, and
# failing that (a hard kill with no disconnect) to the proxy's own device watchdog (~15s
# after the utun disappears), with the /var/run pidfile reclaimed at the next reboot.
# /etc/resolver files are likewise root-owned and left to the startup sweep (prompting
# for sudo inside a trap is worse).
trap '
    [ -n "${KA_PID:-}" ] && kill "$KA_PID" 2>/dev/null || true
    rm -f "$KA_DNS_FILE" 2>/dev/null || true
' EXIT

echo ">> connecting tunnel (sudo)" >&2
printf '%s' "$COOKIE" | sudo "$OPENCONNECT" "$@" "$CONNECT_URL"

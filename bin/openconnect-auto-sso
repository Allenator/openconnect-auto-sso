#!/bin/sh
# openconnect-auto-sso — connect to a browser-SSO VPN in two phases so the
# login browser never runs as root:
#   Phase 1 (as you):   openconnect --authenticate --external-browser=<helper>
#                       -> prints COOKIE / CONNECT_URL / FINGERPRINT / RESOLVE
#   Phase 2 (sudo):     openconnect --cookie-on-stdin ...  (no browser)
#
# All site-specifics come from a TOML config (see config.example.toml).
set -eu

# --- locate the project (works when symlinked into ~/.local/bin) -------------
# Resolve our OWN real path by following any symlink chain. Used BOTH to derive $PROJ and to
# key the test-seam guard below on the REAL file, so a differently-named symlink can bypass
# neither. Runs unconditionally (even under the seam) so the guard always has it.
src=$0
_n=0
while [ -L "$src" ]; do
    _n=$((_n + 1))
    [ "$_n" -gt 40 ] && { echo "error: too many symlink levels resolving $0" >&2; exit 1; }
    dir=$(cd "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case $src in /*) ;; *) src=$dir/$src ;; esac
done

# The OC_CONNECT_TEST seam (used further below) exists ONLY for the test harness to SOURCE
# this file and exercise the pure helpers. If it leaks into a real EXECUTED run, the whole
# connect flow would be guarded off and the script would exit 0 having done nothing -- a
# silent no-op, the worst failure for a VPN tool -- and a poisoned OC_PROJ could then redirect
# $PROJ (which selects lib/common.sh and the vpn-browser/vpnc-slice helpers). Refuse LOUDLY
# here, keyed on our RESOLVED basename ($src, symlinks followed) and BEFORE sourcing anything
# from $PROJ: a real EXECUTED run resolves to openconnect-auto-sso even via a renamed symlink
# and is caught; a `.`-source leaves $0 as the caller's ("sh" under the
# harness), whose basename is never ours, so the seam tests are unaffected.
if [ "${OC_CONNECT_TEST:-}" = 1 ]; then
    case ${src##*/} in
        openconnect-auto-sso)
            echo "error: OC_CONNECT_TEST=1 is set but this connect script is being EXECUTED," >&2
            echo "       not sourced by the test harness -- refusing to silently no-op. Unset it." >&2
            exit 1 ;;
    esac
fi

# Normally $PROJ is $src-derived. Honor the OC_PROJ override ONLY under the test seam
# (OC_CONNECT_TEST=1 -- proven a SOURCED run by the guard above); a stray/poisoned OC_PROJ in
# a real run must NOT redirect $PROJ (which selects lib/common.sh + the helper scripts).
if [ "${OC_CONNECT_TEST:-}" = 1 ] && [ -n "${OC_PROJ:-}" ]; then
    PROJ="$OC_PROJ"
else
    PROJ=$(cd "$(dirname "$src")/.." && pwd)
fi

. "$PROJ/lib/common.sh"   # RESOLVER_MARKER, TEARDOWN_BIN, and the recovery timing +
                          # helpers (wait_for_server, RECONNECT_TIMEOUT_*, NET_WAIT_MAX)

# --- pure helpers, defined BEFORE the OC_CONNECT_TEST seam --------------------
# These have no side effects at definition time, so a test can source this script under
# OC_CONNECT_TEST=1 (which guards off the whole connect flow below) and exercise them in
# isolation -- no config load, no startup sweep, no auth, no sudo.
#
# _shq: emit $1 as a safely single-quoted shell word (embedded ' -> '\''), so a space or
# apostrophe in a path survives openconnect re-parsing the Phase-2 -s string via sh.
_shq() { printf "'"; printf '%s' "$1" | sed "s/'/'\\\\''/g"; printf "'"; }

# apply_launch_budget: feed the launch mode ($OC_LAUNCHD: unset|once|keepalive, set only by
# the LaunchAgent plist) to recovery_budget, which picks the reconnect + network-wait budgets
# (lib/common.sh owns the rationale). Wrapped so the seam can exercise the OC_LAUNCHD wiring.
apply_launch_budget() { recovery_budget "${OC_LAUNCHD:-}"; }

# _mtu_degraded: return 0 (degraded) iff $1 answers a SMALL ping but NOT a large don't-fragment
# ping -- the signature of a tunnel whose path MTU collapsed to the 576 floor (openconnect's
# in-process RESUME can re-probe over a still-flaky path, misread lost probes as "MTU too big",
# ratchet down, and stay there: large packets fail while small ones work). The small-ping gate
# rules out tunnel-down / unreachable false positives -- those return 1 ("not degraded / can't
# tell"), NEVER 0, so the heal path can't fire on a plain outage. Best-effort and set-e-safe:
# every ping is guarded (|| return / && return), so a failing probe returns a verdict, never
# aborts a set -eu caller. macOS /sbin/ping: -c 1 = one packet, -t = timeout secs, -D = set the
# don't-fragment bit, -s = payload bytes (1200+28 = 1228 > the 576 floor and <= a healthy ~1280).
# PING_BIN / MTU_PROBE_SIZE are read at call time and defaulted HERE too, not just with the
# other env vars below: those live inside the OC_CONNECT_TEST seam, so a sourced caller under
# set -u would trip on an unset PING_BIN. PING_BIN is an override only so tests can stub the
# probe (the keepalive runs as the user).
_mtu_degraded() {   # $1 = probe host
    _p="${PING_BIN:-/sbin/ping}"
    "$_p" -c 1 -t 3 "$1" >/dev/null 2>&1 || return 1                                  # unreachable
    "$_p" -c 1 -t 3 -D -s "${MTU_PROBE_SIZE:-1200}" "$1" >/dev/null 2>&1 && return 1  # large DF ok -> healthy
    return 0                                                                           # small ok, large fails
}

# _build_vs: assemble the Phase-2 `-s` wrapper string into $vs from the config-derived globals
# + the resolved $VPN_SLICE abs path. The caller appends `-s "$vs"` to openconnect's argv (the
# `set --` stays in the caller so it edits the caller's positionals). Split out so the seam can
# unit-test the _shq quoting and the --proxy/-I/-S/-i inclusion with no live tunnel.
_build_vs() {
    vs="$(_shq "$PROJ/bin/vpnc-slice")"
    [ -n "${OC_DUMP:-}" ] && vs="$vs --dump-env $(_shq "$OC_DUMP")"        # diagnostic env dump
    [ "$KEEPALIVE_HOST" = "@dns" ] && vs="$vs --write-dns $(_shq "$KA_DNS_FILE")"  # keepalive target
    # DNS-driven auto-routing: resolve these names via the VPN's DNS and route each
    # answered IP through the tunnel (handled by the wrapper + src/dnsroute.py).
    [ -n "$PROXY_NAMES" ] && vs="$vs --proxy $PROXY_NAMES $PROXY_PORT $(_shq "$PROXY_PIDFILE")"
    vs="$vs $(_shq "$VPN_SLICE")"
    # ALLOW_INCOMING=1 drops vpn-slice's pf firewall (keeps iCloud Private Relay working).
    [ "$ALLOW_INCOMING" = "1" ] && vs="$vs -i"
    # Dynamic routes pushed by the VPN (no need to hardcode them):
    [ "$ROUTE_INTERNAL" = "1" ] && vs="$vs -I"        # VPN's own subnet
    [ "$ROUTE_SPLITS" = "1" ] && vs="$vs -S"          # server split-includes
    [ -n "$SPLIT_ROUTES" ] && vs="$vs $SPLIT_ROUTES"  # your explicit subnets
    return 0   # never let a false trailing `[ ] && ...` trip set -e in the caller
}

# --- Phase-1 helper reaping (defined here so the seam can unit-test the run-scoping) --------
# Full argv fragments that identify OUR SSO helper and OUR Phase-1 openconnect (re-confirmed
# via pid_argv_has, lib/common.sh). The helper's argv carries "$PROJ/src/vpn_browser.py";
# Phase-1 openconnect's carries "--external-browser=$PROJ/bin/vpn-browser". Phase 1 now holds
# both real run-scoped PIDs (openconnect is backgrounded -> $!, the helper writes the pidfile),
# so reaping needs NO argv-pattern process scan (no pgrep, which matched editors/pytest and
# couldn't tell concurrent runs apart) -- these literals are only a per-PID re-confirm guarding
# against PID reuse.
_HELPER_FULL="$PROJ/src/vpn_browser.py"
_P1_FULL="external-browser=$PROJ/bin/vpn-browser"

# End the SSO browser helper: SIGTERM it and WAIT for it to exit, rather than a fire-and-forget
# kill. Chromium batches cookie commits (~30s), and the helper needs a moment (its SIGTERM
# handler flushes and lingers ~1.5s) to durably write the session cookie the login just earned
# -- killing it the instant Phase 1 ends can drop it. Bounded, then force-killed, so a
# wedged helper can never stall us. Idempotent: a no-op once the helper is gone (the
# trap-chained 2nd call reads no live PID and returns 0).
#
# Reaps EXACTLY the PID this run's helper recorded in $VPN_BROWSER_PIDFILE, re-confirmed ours
# via pid_argv_has so a reused PID can't be hit. NO argv-pattern fallback: a concurrent
# same-repo run's live helper (a DIFFERENT PID whose argv also matches) is NEVER touched
# (findings 3/8). Removes the pidfile once done. Reads the pidfile with the `read` builtin
# (no `cat` fork) guarded by `[ -f ]`, so a planted FIFO at the path can't stall it.
_end_browser() {
    _pf=${VPN_BROWSER_PIDFILE:-}
    _rec=""; [ -n "$_pf" ] && [ -f "$_pf" ] && { read -r _rec < "$_pf"; } 2>/dev/null || true
    # Nothing recorded OR the recorded PID is not alive -> our helper already exited (self-close
    # after the callback, crash, or a prior _end_browser call). Clean up and return; NEVER
    # pattern-reap (that killed a concurrent run's helper).
    if [ -z "$_rec" ] || ! kill -0 "$_rec" 2>/dev/null; then
        [ -n "$_pf" ] && rm -f "$_pf" 2>/dev/null || true
        return 0
    fi
    if pid_argv_has "$_rec" "$_HELPER_FULL"; then          # PID-reuse guard
        kill -TERM "$_rec" 2>/dev/null || true             # graceful -> helper flushes cookie
        _i=0
        while kill -0 "$_rec" 2>/dev/null; do
            _i=$((_i + 1))
            [ "$_i" -ge 8 ] && { pid_argv_has "$_rec" "$_HELPER_FULL" && kill -KILL "$_rec" 2>/dev/null || true; break; }
            sleep 1
        done
    fi
    [ -n "$_pf" ] && rm -f "$_pf" 2>/dev/null || true
}

# --- everything below is the connect flow; OC_CONNECT_TEST=1 guards it off when sourced ---
if [ "${OC_CONNECT_TEST:-}" != 1 ]; then

# --- load configuration ------------------------------------------------------
# Precedence: $OC_AUTO_SSO_CONFIG, then the standard external location
# ~/.config/openconnect-auto-sso/config.toml, then an in-repo config.toml (dev only).
XDG_CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/openconnect-auto-sso/config.toml"
if [ -n "${OC_AUTO_SSO_CONFIG:-}" ]; then
    CONFIG="$OC_AUTO_SSO_CONFIG"
elif [ -f "$XDG_CONFIG" ]; then
    CONFIG="$XDG_CONFIG"
elif [ -f "$PROJ/config.toml" ]; then
    CONFIG="$PROJ/config.toml"
else
    CONFIG="$XDG_CONFIG"
fi
if [ ! -f "$CONFIG" ]; then
    echo "error: no config found (expected $XDG_CONFIG)" >&2
    echo "       mkdir -p \"$(dirname "$XDG_CONFIG")\" && cp \"$PROJ/config.example.toml\" \"$XDG_CONFIG\"   # then edit server" >&2
    exit 1
fi
# Parse the TOML config into shell variables. The parser validates and shell-quotes
# each value; the config is never sourced, so it cannot execute code or inject shell.
PY="$PROJ/.venv/bin/python"; [ -x "$PY" ] || PY=python3
_conf=$("$PY" "$PROJ/src/loadconfig.py" "$CONFIG") || exit 1
eval "$_conf"

: "${SERVER:?server is required in the config}"
PROTOCOL="${PROTOCOL:-}"
SPLIT_ROUTES="${SPLIT_ROUTES:-}"
PROFILE_NAME="${PROFILE_NAME:-openconnect-auto-sso}"
CALLBACK="${CALLBACK:-localhost:29786}"
KEEPALIVE_HOST="${KEEPALIVE_HOST:-}"
KEEPALIVE_INTERVAL="${KEEPALIVE_INTERVAL:-30}"
# Pick the reconnect budget + network-wait bound from OC_LAUNCHD (lib/common.sh owns the
# rationale). The auto-start agent exports OC_LAUNCHD=keepalive|once in its plist; nothing
# else does, so a lone run reads as unset and keeps openconnect's long in-process budget
# (nothing would respawn it). An explicit `reconnect_timeout` from the config still wins.
apply_launch_budget
ALLOW_INCOMING="${ALLOW_INCOMING:-0}"
MTU_HEALTHCHECK="${MTU_HEALTHCHECK:-1}" # heal a collapsed tunnel MTU (needs keepalive; see below)
PING_BIN="${PING_BIN:-/sbin/ping}"      # keepalive + MTU probes; override only for tests (runs as user)
PROXY_NAMES="${PROXY_NAMES:-}"          # DNS names routed via the VPN (proxy + /etc/resolver)
ROUTE_INTERNAL="${ROUTE_INTERNAL:-0}"   # also route the VPN's own subnet (server-pushed)
ROUTE_SPLITS="${ROUTE_SPLITS:-0}"       # also add the server's split-include subnets
PROXY_PORT="${PROXY_PORT:-45353}"       # loopback port for the DNS-routing proxy
# Private per-run scratch dir (0700, unpredictable name). Holds the helper pidfile, the
# keepalive @dns target, the Phase-1 auth capture, and the backstop flag -- so none live in
# world-writable /tmp, where an unset TMPDIR (ssh/cron) would otherwise put them
# and a pre-planted symlink/FIFO could redirect or block a write. mktemp -d makes it per-run,
# so the files inside need no $$; the EXIT trap rm -rf's it. (KA_DNS_FILE is written by the
# ROOT wrapper via sudo -- root can create inside our 0700 dir, and we own the dir so we can
# still remove it on exit.)
_rundir=$(mktemp -d "${TMPDIR:-/tmp}/oc-sso.XXXXXX") \
    || { echo "error: could not create a private run directory" >&2; exit 1; }
# MINIMAL cleanup traps, armed the instant $_rundir exists -- its own EXIT/signal traps aren't
# installed until Phase 1 (~150 lines below), so an exit or signal in the gap (openconnect-not-
# found exit 1; a signal during wait_for_server's up-to-300s window) would otherwise leak the
# 0700 dir. The Phase-1 traps (below) later REPLACE these.
trap 'rm -rf "${_rundir:-}" 2>/dev/null || true' EXIT
trap 'rm -rf "${_rundir:-}" 2>/dev/null || true; exit 130' INT TERM
KA_DNS_FILE="$_rundir/dns"                  # keepalive @dns target (root wrapper writes it)
# Helper pidfile: the SSO helper records its own PID here so _end_browser reaps EXACTLY this
# run's helper by PID -- not every same-repo helper by argv pattern, which would kill a
# CONCURRENT run's live login mid-flow (the launchd agent + a manual run both in Phase 1).
# Inside $_rundir (private 0700), and the helper opens it O_NOFOLLOW (src/vpn_browser.py).
# See _end_browser (defined above).
VPN_BROWSER_PIDFILE="$_rundir/helper.pid"
# Proxy state file (PER-PORT path, keyed on $PROXY_PORT): line 1 = the dnsroute PID,
# line 2 = the owning openconnect PID (VPNPID). A stable per-port path lets a fresh run on
# the SAME port reason about a PREVIOUS run's proxy -- reclaim our own (in-process
# reconnect) or an orphan a crash left holding the port (see the wrapper) -- while two
# tunnels on DIFFERENT ports get DIFFERENT files, so neither clobbers the other's record.
# There is no "refuse a second instance": the wrapper gates every proxy-state mutation on
# an ownership invariant (owner == VPNPID, or the owner is no longer a live openconnect),
# so a live DIFFERENT tunnel on the same port is left untouched -- our own dnsroute then
# fails to bind and degrades to a clear "DNS-routing disabled (port busy)" warning, no
# lockout and no cross-instance root-kill (launchd already stops the agent double-running).
# It drives a ROOT kill in the wrapper, so it lives in /var/run (root:daemon, 0775): a
# user-writable path would let the tunnel's own user seed a victim PID for root to signal,
# and the invoking user isn't in group daemon. Only the wrapper (root) writes it.
PROXY_PIDFILE="/var/run/openconnect-auto-sso.proxy.$PROXY_PORT"

# The SSO browser helper (spawned by openconnect) reads these from the env. VPN_BROWSER_PIDFILE
# is where it records its own PID so we can reap exactly this run's helper.
export PROFILE_NAME CALLBACK VPN_BROWSER_PIDFILE

# --- startup guards for leftovers from failed teardowns ----------------------
# Shared prompt tail: on a tty, ask QUESTION (default answer DEFAULT) and run
# FIX_FN on yes; if the fix didn't run (no tty, declined, failed), print the
# manual LATER_HINT. Always returns 0.
#   _offer_sudo_fix QUESTION DEFAULT(y|n) LATER_HINT FIX_FN
_offer_sudo_fix() {
    _q=$1; _def=$2; _later=$3; _fn=$4
    _fixed=n
    if [ -t 0 ]; then
        [ "$_def" = y ] && _yn='[Y/n]' || _yn='[y/N]'
        printf "  %s (needs sudo)? %s " "$_q" "$_yn" >&2
        read -r _ans || _ans=$_def
        case "$_ans" in [yY]*) _do=y ;; [nN]*) _do=n ;; *) _do=$_def ;; esac
        [ "$_do" = y ] && "$_fn" && _fixed=y || true
    fi
    [ "$_fixed" = y ] || echo "  Clean later:  $_later" >&2
}

# vpn-slice's "block incoming" firewall appends an anchor to /etc/pf.conf and can
# fail to remove it on teardown. The leftover reloads on every boot and keeps
# iCloud Private Relay disabled even with no VPN connected. Warn (and offer to fix).
_fix_pf_anchor() {
    if sudo cp /etc/pf.conf /etc/pf.conf.bak &&
       sudo sed -i '' '/anchor "vpn_slice/d' /etc/pf.conf &&
       sudo pfctl -f /etc/pf.conf 2>/dev/null; then
        echo "  cleaned (backup at /etc/pf.conf.bak)." >&2
    else
        echo "  cleanup failed; remove the line manually." >&2
        return 1
    fi
}
if [ -r /etc/pf.conf ] && grep -q 'anchor "vpn_slice' /etc/pf.conf 2>/dev/null; then
    echo "WARNING: leftover vpn-slice firewall anchor in /etc/pf.conf:" >&2
    grep -n 'anchor "vpn_slice' /etc/pf.conf | sed 's/^/    /' >&2
    echo "  It persists across reboots and can keep iCloud Private Relay off even" >&2
    echo "  with no VPN connected (a vpn-slice teardown bug)." >&2
    _offer_sudo_fix "Remove it now" n \
        "sudo sed -i '' '/anchor \"vpn_slice/d' /etc/pf.conf && sudo pfctl -f /etc/pf.conf" \
        _fix_pf_anchor
fi

# Our resolver files (first line: $RESOLVER_MARKER) point domains at the loopback
# DNS proxy; if a teardown was missed they outlive the proxy and break every
# lookup under those domains -- including Phase 1's resolution of $SERVER when it
# sits under one of them. The marker guarantees we only touch our own.
_rm_resolver_leftovers() {
    # $_leftover intentionally word-splits into the individual paths; `set -f`
    # (in a subshell, so it doesn't leak) stops those paths being re-globbed --
    # a resolver filename could contain a shell glob metacharacter.
    ( set -f; sudo rm -f $_leftover ) && echo "  removed." >&2
}
_leftover=""
for _f in /etc/resolver/*; do
    [ -f "$_f" ] || continue
    grep -qxF -- "$RESOLVER_MARKER" "$_f" 2>/dev/null && _leftover="$_leftover $_f" || true
done
if [ -n "$_leftover" ]; then
    if pgrep -x openconnect >/dev/null 2>&1; then
        echo "WARNING: an openconnect is already running; leaving its resolver files:$_leftover" >&2
    else
        echo "WARNING: leftover DNS resolver files from an earlier session:" >&2
        for _f in $_leftover; do echo "    $_f" >&2; done
        echo "  They point those domains at a proxy that is no longer running, so" >&2
        echo "  lookups under them fail -- and can break this connect." >&2
        if [ ! -t 0 ] && [ -x "$TEARDOWN_BIN" ]; then
            # Non-interactive (e.g. under the LaunchAgent): can't prompt, and this
            # user-domain sweep can't sudo-rm root-owned files. Delegate to the
            # root-owned teardown helper (scoped NOPASSWD) to heal them.
            sudo -n "$TEARDOWN_BIN" --sweep 2>/dev/null && echo "  swept via teardown helper." >&2 \
                || echo "  Clean later:  sudo rm$_leftover" >&2
        else
            # Default Yes (unlike the pf guard): the marker proves they're ours, no
            # openconnect is running, and keeping them breaks DNS machine-wide.
            _offer_sudo_fix "Remove them now" y "sudo rm$_leftover" _rm_resolver_leftovers
        fi
    fi
fi

# Resolve openconnect to an absolute path and use it for BOTH phases. Phase 2 runs
# it via sudo; passing the absolute path makes the NOPASSWD sudoers drop-in from
# install-autostart.sh (which pins openconnect's absolute path) match
# deterministically -- independent of sudo's secure_path / the invoking PATH, which
# a bare `sudo openconnect` would depend on.
OPENCONNECT=$(command -v openconnect || true)
[ -n "$OPENCONNECT" ] || { echo "error: openconnect not found on PATH" >&2; exit 1; }

# A wake from sleep -- or a login before Wi-Fi associates -- can leave us with no usable
# network yet. Authenticating into that fails instantly and exits non-zero, and under
# launchd that burns a throttled retry (respawn is delayed by THROTTLE_INTERVAL minus our
# runtime). So WAIT for the server to actually be reachable instead: staying alive is
# always cheaper than exiting into the throttle. wait_for_server (and NET_WAIT_MAX, already
# sized by recovery_budget above: the full throttle window under either launch-agent mode
# (keepalive or once), a short bound for a manual run) live in lib/common.sh. Best-effort: on
# timeout we fall through under `|| true`
# and let Phase 1 report the real error -- WITHOUT the `|| true`, a set -eu abort here would
# kill the whole connect on a slow network, the opposite of "wait and proceed".
wait_for_server "$SERVER" || true

# --- Phase 1: authenticate as the current user (no sudo, no root browser) ----
echo ">> authenticating to $SERVER" >&2

COOKIE=''; HOST=''; CONNECT_URL=''; FINGERPRINT=''; RESOLVE=''
# Preserve the tty on fd 3 for openconnect's UNTRUSTED-CERT prompt: backgrounding a child
# reassigns its stdin to /dev/null, and Phase 1 passes no --servercert, so that prompt is
# real -- the bg openconnect reads the tty via <&3. Released before Phase 2's --cookie-on-stdin.
# A niche spawner that CLOSES fd 0 (rather than /dev/null'ing it) makes a bare `exec 3<&0` fail;
# `exec` is a special built-in, so a failed redirection ABORTS the whole connect --
# and a trailing `|| ...` can't catch it (the shell has already exited), while `exec 3<&0
# 2>/dev/null` would PERMANENTLY silence stderr (the `2>` on a command-less exec outlives it). So
# probe fd 0's dup-ability in a SUBSHELL first (its exec-exit + the stderr suppression stay
# confined there -- `n<&n` is a no-op some shells never fail, hence a high fd), then dup the real
# stdin onto fd 3 only if it is open, else fall back to /dev/null (no tty for the cert prompt,
# exactly as when backgrounded).
if ( exec 7<&0 ) 2>/dev/null; then exec 3<&0; else exec 3</dev/null; fi

# Validate the (documented) deadline knob: a non-integer makes `sleep` fail -> set -e would
# disable the whole backstop; 0/negative would fire it against the just-started login. -> 420.
PHASE1_DEADLINE="${PHASE1_DEADLINE:-420}"
case $PHASE1_DEADLINE in
    ''|*[!0-9]*) PHASE1_DEADLINE=420 ;;
    *) [ "$PHASE1_DEADLINE" -gt 0 ] || PHASE1_DEADLINE=420 ;;
esac

# Dead-man backstop, ARMED by a flag file that EXISTS; DISARMED by removing it. Correctness
# NEVER depends on signaling a pid: openconnect frees a reaped bg child's pid, so a raw
# `kill $pid` could hit a reused pid -- so we disarm by REMOVING the flag and reap
# the backstop with `wait`, never a kill. Init the temps the traps reference BEFORE arming (set -u).
# (_p1_wd is NOT trap-referenced and is always $!-assigned before its lone `wait`, so it needs no init.)
_p1_flag="$_rundir/p1armed"
_authtmp=''; _oc_pid=''
: > "$_p1_flag"

# EXIT (covers a FAILED Phase 1 too): drop the flag + auth tempfile, reap the helper,
# remove the run dir. The whole body is guarded `{ ...; } || true` so a failing rm can't trip
# set -e and skip _end_browser. Replaced once Phase 2 owns cleanup.
trap '{ rm -f "${_p1_flag:-}" "${_authtmp:-}" 2>/dev/null; _end_browser; rm -rf "${_rundir:-}" 2>/dev/null; } || true' EXIT
# INT/TERM: disarm, then TERM OUR openconnect (guarded -- an unguarded failing kill would abort
# the trap and skip _end_browser), then reap the helper and exit. The kill is ESSENTIAL under
# launchd (bootout SIGTERMs only this script, not the bg openconnect) and harmless in a terminal
# (Ctrl-C already reached openconnect via the foreground process group).
trap 'rm -f "${_p1_flag:-}" 2>/dev/null; kill "${_oc_pid:-}" 2>/dev/null || true; _end_browser; exit 130' INT TERM

# Background openconnect so we HOLD its real pid ($!). Keep its stdin (the tty, via fd 3) and
# its stderr (the terminal); capture STDOUT ONLY -- the eval-able COOKIE=/HOST=/FINGERPRINT=/
# RESOLVE= lines. NOT 2>&1: stderr (progress/prompts) would corrupt `eval "$auth_out"`.
# TRADEOFF: backgrounding forces the session cookie briefly to disk here (the old
# foreground capture kept it in memory). ACCEPTED as inherent to backgrounding, mitigated by the
# 0600 tempfile inside the 0700 $_rundir and unlinked the instant it is read (below).
_authtmp=$(mktemp "$_rundir/oc-auth.XXXXXX")
if [ -n "$PROTOCOL" ]; then
    "$OPENCONNECT" --protocol="$PROTOCOL" \
        --external-browser="$PROJ/bin/vpn-browser" --authenticate "$SERVER" <&3 >"$_authtmp" &
else
    "$OPENCONNECT" \
        --external-browser="$PROJ/bin/vpn-browser" --authenticate "$SERVER" <&3 >"$_authtmp" &
fi
_oc_pid=$!

# The backstop fires ONLY IF, at the deadline and STILL armed, OUR openconnect is alive AND OUR
# helper is truly gone -- both re-confirmed by argv on the EXACT pids (a reused oc-pid can't
# make us kill an innocent; a reused helper-pid can't fake "alive"). openconnect's callback
# listener is select(...,NULL) -- no timeout -- and never watches the helper, so a helper that
# dies WITHOUT reaching the callback AND without signaling (exec-fail / crash / SIGKILL) would
# otherwise wedge `wait "$_oc_pid"` below forever. A live helper means a real (possibly slow:
# password + Duo) login -- NEVER killed (mirrors the browser's own hard-timer suspension).
(
    # Ignore SIGPIPE inside the backstop. The `|| true` on the stderr echo
    # below only catches an EPIPE *return*; with SIGPIPE at its DEFAULT disposition a broken
    # stderr pipe would KILL this subshell (status 141) BEFORE the kill -TERM that frees a wedged
    # openconnect -> `wait "$_oc_pid"` then hangs the connect forever. `trap '' PIPE` makes the
    # write return EPIPE (caught by the `|| true`) instead of signalling, so the kill still fires.
    trap '' PIPE
    _n=0
    while [ "$_n" -lt "$PHASE1_DEADLINE" ]; do
        [ -e "$_p1_flag" ] || exit 0            # disarmed (Phase 1 finished) -> stand down
        sleep 1; _n=$((_n + 1))
    done
    [ -e "$_p1_flag" ] || exit 0
    kill -0 "$_oc_pid" 2>/dev/null || exit 0    # our openconnect already gone -> nothing to abort
    pid_argv_has "$_oc_pid" "$_P1_FULL" || exit 0            # reused oc-pid -> not ours -> stand down
    _rec=$(cat "$VPN_BROWSER_PIDFILE" 2>/dev/null || true)   # GUARDED (helper-gone == pidfile absent)
    if [ -n "$_rec" ] && kill -0 "$_rec" 2>/dev/null && pid_argv_has "$_rec" "$_HELPER_FULL"; then
        exit 0                                  # slow-but-live login -> never kill it
    fi
    # Secondary liveness check: write_own_pidfile is best-effort (it swallows
    # OSError), so an ABSENT pidfile can mean "helper LIVE but its write failed", not "helper
    # gone". Before killing a possibly-real login, confirm OUR openconnect has NO live child --
    # the helper is openconnect's DIRECT child (bin/vpn-browser exec's python). A guarded `if`,
    # NOT `pgrep ... && exit 0` (which would trip the subshell's set -e on a no-match); a live
    # child means the login is real -> stand down.
    if pgrep -P "$_oc_pid" >/dev/null 2>&1; then exit 0; fi
    # `|| true`: a failed stderr write (ENOSPC/EPIPE) must NOT, under the subshell's
    # set -e, abort BEFORE the kill below -- that would leave openconnect wedged and hang `wait`.
    echo "error: Phase 1 stalled ${PHASE1_DEADLINE}s with the SSO helper gone -- aborting." >&2 || true
    kill -TERM "$_oc_pid" 2>/dev/null || true
) &
_p1_wd=$!

if wait "$_oc_pid"; then _auth_rc=0; else _auth_rc=$?; fi   # set-e-safe capture of openconnect's rc
_oc_pid=''                            # openconnect reaped -> clear so the INT/TERM trap can't raw-kill a FREED/reused pid

rm -f "$_p1_flag"                     # disarm WITHOUT signaling: the backstop self-exits on its next tick
wait "$_p1_wd" 2>/dev/null || true    # reap the backstop by wait (its remembered status; never signals -> reuse-proof)

auth_out=$(cat "$_authtmp"); rm -f "$_authtmp"; _authtmp=''
[ "$_auth_rc" = 0 ] || { echo "error: authentication failed" >&2; exit 1; }
exec 3<&-                             # release the preserved stdin before Phase 2's --cookie-on-stdin

# Phase 1 done, so the SSO browser is no longer needed. Some servers complete the SSO
# server-side (no localhost callback), so the helper cannot self-close -- end it here
# (terminate-then-wait, so its just-earned cookie is durably flushed first).
_end_browser

# Phase 2 signal handling. In a terminal, Ctrl-C reaches the root openconnect child
# directly via the foreground process group, so we clear our trap and let openconnect
# run its own clean disconnect. Under launchd there is no controlling tty, so the
# signal reaches only this (user) script and not the root child -- so invoke the
# privileged teardown helper (installed root-owned + scoped-NOPASSWD by
# install-autostart.sh) to SIGTERM openconnect for a clean disconnect. `sudo -n`
# never prompts: if the helper/rule isn't present it fails fast and we just exit.
# Test stdin (matches the startup sweep's `[ ! -t 0 ]`), so a manual run with only
# stderr redirected still takes the terminal path.
if [ -t 0 ]; then
    trap - INT TERM
else
    trap '[ -x "$TEARDOWN_BIN" ] && sudo -n "$TEARDOWN_BIN" 2>/dev/null; exit 143' INT TERM
fi

eval "$auth_out"   # sets COOKIE / HOST / CONNECT_URL / FINGERPRINT / RESOLVE

if [ -z "$COOKIE" ]; then
    echo "error: no session cookie (login cancelled, or server has no SSO)" >&2
    exit 1
fi

# --- Phase 2: build the tunnel as root (no browser involved) -----------------
# NOTE: deliberately NO --setuid. On macOS, dropping privileges makes openconnect
# run the DISCONNECT vpnc-script as the unprivileged user, which then cannot
# restore routes or DNS -- leaving the machine with no default route and stale VPN
# DNS servers after you disconnect. Staying root for the tunnel's lifetime lets
# teardown cleanly undo everything.
set -- --cookie-on-stdin --servercert "$FINGERPRINT"
[ -n "$RESOLVE" ] && set -- "$@" --resolve "$RESOLVE"
[ -n "$PROTOCOL" ] && set -- "$@" --protocol="$PROTOCOL"
# Budget for openconnect's own in-process reconnect; sized by launch mode ($OC_LAUNCHD, via
# apply_launch_budget above). lib/common.sh owns the rationale (why a sleep needs a FRESH
# connect, not a reconnect).
set -- "$@" --reconnect-timeout="$RECONNECT_TIMEOUT"
if [ -n "$SPLIT_ROUTES$PROXY_NAMES" ] || [ "$ROUTE_INTERNAL" = "1" ] || [ "$ROUTE_SPLITS" = "1" ]; then
    # root's PATH usually excludes Homebrew, so resolve vpn-slice to an abs path.
    VPN_SLICE=$(command -v vpn-slice || true)
    [ -n "$VPN_SLICE" ] || { echo "error: split/DNS options set but vpn-slice not found" >&2; exit 1; }
    # Name-based routing starts src/dnsroute.py (needs the venv + dnspython) as root
    # inside the wrapper, where a failure would be silent. Pre-flight it here, in the
    # user domain, so a broken install fails loudly BEFORE we bring the tunnel up.
    if [ -n "$PROXY_NAMES" ]; then
        if [ ! -x "$PROJ/.venv/bin/python" ] || \
           ! "$PROJ/.venv/bin/python" -c 'import dns.message' 2>/dev/null; then
            echo "error: DNS-routing (a name in via_vpn) needs the bundled venv with" >&2
            echo "       dnspython at $PROJ/.venv -- run 'uv sync' in the repo." >&2
            exit 1
        fi
    fi
    # Route through the vpnc-slice wrapper so the DNS-routing proxy and the @server
    # token can use the VPN's pushed CISCO_SPLIT_DNS/CISCO_DEF_DOMAIN/INTERNAL_IP4_DNS
    # (sudo strips our env, so the wrapper's config is baked into this -s string).
    # openconnect runs this whole -s string via `/bin/sh -c`, which re-splits it on
    # spaces, so PATH-valued fields are single-quoted (_shq) to survive a space -- or
    # an apostrophe -- in $PROJ or $TMPDIR. The unquoted fields (PROXY_NAMES/
    # PROXY_PORT/SPLIT_ROUTES) are validated by loadconfig to contain no spaces or
    # shell metacharacters.
    _build_vs                 # sets $vs from the config globals + $VPN_SLICE (helper above)
    set -- "$@" -s "$vs"
fi
# Full tunnel (no split/DNS options) needs no -s: openconnect uses its own default
# vpnc-script. Clean teardown still works -- vpn-teardown finds openconnect by name.

# Optional keepalive: some servers drop an idle tunnel. Ping a host *inside* the
# VPN periodically so a little traffic keeps flowing. The subshell watches the
# script's PID and stops when we exit (belt-and-suspenders with the EXIT trap).
#
# The same loop doubles as an MTU-collapse healer (MTU_HEALTHCHECK=1, default): openconnect's
# in-process RESUME after a same-IP Wi-Fi blip can re-probe the path MTU over a still-flaky link,
# ratchet it to the 576 floor, and stay there -- a "connected" tunnel where large packets fail
# (browser timeouts) but small ones work. A FRESH connect re-probes on a settled path and is
# immune, so when we PROVE the MTU collapsed we force a fresh reconnect via the root teardown
# helper (openconnect exits -> this script exits -> launchd respawns a clean connect). The
# subshell survives openconnect's in-process reconnects (it watches $$, the connect-script PID,
# which is stable across them), so it can observe the post-resume degradation. Healing REUSES the
# keepalive target + loop, so it is active only when keepalive is on.
if [ -n "$KEEPALIVE_HOST" ]; then
    if [ "$KEEPALIVE_HOST" = "@dns" ]; then
        # KA_DNS_FILE ($_rundir/dns) is written by the ROOT wrapper once the tunnel is up; the
        # rundir is a fresh mktemp -d nothing wrote before now, so no stale file to clear here.
        echo ">> keepalive: ping the VPN's DNS server every ${KEEPALIVE_INTERVAL}s" >&2
    else
        echo ">> keepalive: ping $KEEPALIVE_HOST every ${KEEPALIVE_INTERVAL}s" >&2
    fi
    # Healing works by making openconnect EXIT and letting a respawn bring up a clean tunnel, so
    # it is only safe when something WILL respawn us: the KeepAlive agent (OC_LAUNCHD=keepalive).
    # Under `install --once` or a manual run nothing does (the same asymmetry recovery_budget
    # encodes when it picks the reconnect budget), so healing there would take a degraded-but-up
    # tunnel permanently down -- strictly worse than the collapsed MTU it fixes. Refuse instead.
    if [ "$MTU_HEALTHCHECK" = "1" ] && [ "${OC_LAUNCHD:-}" != keepalive ]; then
        MTU_HEALTHCHECK=0
        echo ">> keepalive: MTU healing off (nothing would respawn a healed tunnel -- it needs" \
             "the KeepAlive agent: ./install-autostart.sh install)" >&2 || true
    fi
    [ "$MTU_HEALTHCHECK" = "1" ] && \
        echo ">> keepalive: also healing a collapsed tunnel MTU via a fresh reconnect" >&2 || true
    # _mtu_base: pending -> ok (a large-DF ping got through once, so the target does NOT block
    # large ICMP and we can trust the degradation check) -> off (never got through after a few
    # tries: the target blocks large ICMP, or this connect is ALREADY degraded -- either way,
    # disable the check to avoid a false heal / heal-loop). _fail: consecutive degraded readings.
    # Everything here is best-effort (|| true / condition context) so nothing aborts the subshell.
    ( _fail=0; _mtu_base=pending; _mtu_tries=0
      while kill -0 "$$" 2>/dev/null; do
          if [ "$KEEPALIVE_HOST" = "@dns" ]; then
              host=$(cat "$KA_DNS_FILE" 2>/dev/null || true)
          else
              host="$KEEPALIVE_HOST"
          fi
          [ -n "$host" ] && "$PING_BIN" -c 1 -t 5 "$host" >/dev/null 2>&1 || true
          if [ "$MTU_HEALTHCHECK" = "1" ] && [ -n "$host" ] && [ "$_mtu_base" != off ]; then
              if [ "$_mtu_base" = pending ]; then
                  if "$PING_BIN" -c 1 -t 3 -D -s "${MTU_PROBE_SIZE:-1200}" "$host" >/dev/null 2>&1; then
                      _mtu_base=ok
                  else
                      _mtu_tries=$((_mtu_tries + 1))
                      if [ "$_mtu_tries" -ge "${MTU_HEALTHCHECK_BASELINE_TRIES:-5}" ]; then
                          _mtu_base=off
                          echo ">> keepalive: MTU healthcheck disabled ($host never answered a large" \
                               "ping -- it blocks large ICMP, or the tunnel is already degraded)" >&2 || true
                      fi
                  fi
              elif _mtu_degraded "$host"; then
                  _fail=$((_fail + 1))
                  if [ "$_fail" -ge "${MTU_HEALTHCHECK_FAILS:-2}" ]; then
                      # Only claim the heal (and stop watching) if the teardown actually ran --
                      # sudo -n fails when the NOPASSWD rule is missing, and reporting a reconnect
                      # we never forced would leave a degraded tunnel up with the loop gone.
                      if sudo -n "$TEARDOWN_BIN" 2>/dev/null; then
                          echo ">> keepalive: tunnel MTU collapsed ($host answers small pings but" \
                               "not large ones); forced a fresh reconnect" >&2 || true
                          break                        # openconnect exits -> we exit -> respawn
                      fi
                      echo ">> keepalive: tunnel MTU collapsed ($host answers small pings but not" \
                           "large ones) but the teardown helper did not run -- leaving it up" >&2 || true
                      _fail=0                          # re-arm; retry rather than spin every check
                  fi
              else
                  _fail=0
              fi
          fi
          sleep "$KEEPALIVE_INTERVAL"
      done ) &
    KA_PID=$!
fi

# Clean up on exit: stop the keepalive pinger and rm -rf the private run dir (which holds the
# keepalive @dns target among other per-run temps). The DNS-routing proxy and its pidfile are
# owned by ROOT (the wrapper starts the proxy and writes the pidfile under /var/run), so this
# unprivileged trap can neither signal the
# proxy nor unlink the pidfile -- both are left to the wrapper's disconnect pass, and
# failing that (a hard kill with no disconnect) to the proxy's own device watchdog (~15s
# after the utun disappears), with the /var/run pidfile reclaimed at the next reboot.
# /etc/resolver files are likewise root-owned and left to the startup sweep (prompting
# for sudo inside a trap is worse).
trap '
    [ -n "${KA_PID:-}" ] && kill "$KA_PID" 2>/dev/null || true
    rm -rf "${_rundir:-}" 2>/dev/null || true
' EXIT

echo ">> connecting tunnel (sudo)" >&2
printf '%s' "$COOKIE" | sudo "$OPENCONNECT" "$@" "$CONNECT_URL"

fi   # end OC_CONNECT_TEST seam (the connect flow above never runs when sourced)

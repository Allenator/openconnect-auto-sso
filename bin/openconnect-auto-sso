#!/bin/sh
# openconnect-auto-sso — connect to a browser-SSO VPN in two phases so the
# login browser never runs as root:
#   Phase 1 (as you):   openconnect --authenticate --external-browser=<helper>
#                       -> prints COOKIE / CONNECT_URL / FINGERPRINT / RESOLVE
#   Phase 2 (sudo):     openconnect --cookie-on-stdin ...  (no browser)
#
# All site-specifics come from config.sh (see config.example.sh).
set -eu

# --- locate the project (works when symlinked into ~/.local/bin) -------------
src=$0
while [ -L "$src" ]; do
    dir=$(cd "$(dirname "$src")" && pwd)
    src=$(readlink "$src")
    case $src in /*) ;; *) src=$dir/$src ;; esac
done
PROJ=$(cd "$(dirname "$src")/.." && pwd)

# --- load configuration ------------------------------------------------------
CONFIG="${OC_AUTO_SSO_CONFIG:-$PROJ/config.sh}"
if [ ! -f "$CONFIG" ]; then
    echo "error: no config at $CONFIG" >&2
    echo "       cp config.example.sh config.sh   # then edit SERVER" >&2
    exit 1
fi
# shellcheck disable=SC1090
. "$CONFIG"

: "${SERVER:?SERVER must be set in config.sh}"
PROTOCOL="${PROTOCOL:-}"
SPLIT_ROUTES="${SPLIT_ROUTES:-}"
PROFILE_NAME="${PROFILE_NAME:-openconnect-auto-sso}"
CALLBACK="${CALLBACK:-localhost:29786}"
KEEPALIVE_HOST="${KEEPALIVE_HOST:-}"
KEEPALIVE_INTERVAL="${KEEPALIVE_INTERVAL:-30}"
ALLOW_INCOMING="${ALLOW_INCOMING:-0}"

# The SSO browser helper (spawned by openconnect) reads these from the env.
export PROFILE_NAME CALLBACK

# --- Phase 1: authenticate as the current user (no sudo, no root browser) ----
echo ">> authenticating to $SERVER" >&2
authenticate() {
    if [ -n "$PROTOCOL" ]; then
        openconnect --protocol="$PROTOCOL" \
            --external-browser="$PROJ/bin/vpn-browser" --authenticate "$SERVER"
    else
        openconnect \
            --external-browser="$PROJ/bin/vpn-browser" --authenticate "$SERVER"
    fi
}

COOKIE=''; HOST=''; CONNECT_URL=''; FINGERPRINT=''; RESOLVE=''

# If the user aborts (Ctrl-C) while authentication is still in progress, end the
# SSO browser so it isn't left orphaned (the script would otherwise exit before
# the post-auth pkill below).
trap 'pkill -f "$PROJ/src/vpn_browser.py" 2>/dev/null; exit 130' INT TERM

auth_out=$(authenticate) || { echo "error: authentication failed" >&2; exit 1; }

# Phase 1 done, so the SSO browser is no longer needed. Some servers complete the
# SSO server-side (no localhost callback), so the helper cannot self-close -- end
# it here. (It flushes cookies to disk every few seconds, so nothing is lost.)
pkill -f "$PROJ/src/vpn_browser.py" 2>/dev/null || true
trap - INT TERM   # from here, let Phase 2 handle Ctrl-C for a clean disconnect

eval "$auth_out"   # sets COOKIE / HOST / CONNECT_URL / FINGERPRINT / RESOLVE

if [ -z "$COOKIE" ]; then
    echo "error: no session cookie (login cancelled, or server has no SSO)" >&2
    exit 1
fi

# --- Phase 2: build the tunnel as root (no browser involved) -----------------
# NOTE: deliberately NO --setuid. On macOS, dropping privileges makes openconnect
# run the DISCONNECT vpnc-script as the unprivileged user, which then cannot
# restore routes or DNS -- leaving the machine with no default route and stale VPN
# DNS servers after you disconnect. Staying root for the tunnel's lifetime lets
# teardown cleanly undo everything.
set -- --cookie-on-stdin --servercert "$FINGERPRINT"
[ -n "$RESOLVE" ] && set -- "$@" --resolve "$RESOLVE"
[ -n "$PROTOCOL" ] && set -- "$@" --protocol="$PROTOCOL"
if [ -n "$SPLIT_ROUTES" ]; then
    # root's PATH usually excludes Homebrew, so resolve vpn-slice to an abs path.
    VPN_SLICE=$(command -v vpn-slice || true)
    [ -n "$VPN_SLICE" ] || { echo "error: SPLIT_ROUTES set but vpn-slice not found" >&2; exit 1; }
    # By default vpn-slice blocks incoming VPN traffic via a pf firewall anchor,
    # which also disables iCloud Private Relay. ALLOW_INCOMING=1 passes -i so no
    # pf rule is installed (Private Relay keeps working; VPN hosts can reach you).
    vs_incoming=
    [ "$ALLOW_INCOMING" = "1" ] && vs_incoming="-i "
    set -- "$@" -s "$VPN_SLICE ${vs_incoming}$SPLIT_ROUTES"
fi

# Optional keepalive: some servers drop an idle tunnel. Ping a host *inside* the
# VPN periodically so a little traffic keeps flowing. The subshell watches the
# script's PID and stops when we exit (belt-and-suspenders with the EXIT trap).
if [ -n "$KEEPALIVE_HOST" ]; then
    ( while kill -0 "$$" 2>/dev/null; do
          ping -c 1 -t 5 "$KEEPALIVE_HOST" >/dev/null 2>&1 || true
          sleep "$KEEPALIVE_INTERVAL"
      done ) &
    KA_PID=$!
    trap 'kill "$KA_PID" 2>/dev/null || true' EXIT
    echo ">> keepalive: ping $KEEPALIVE_HOST every ${KEEPALIVE_INTERVAL}s" >&2
fi

echo ">> connecting tunnel (sudo)" >&2
printf '%s' "$COOKIE" | sudo openconnect "$@" "$CONNECT_URL"

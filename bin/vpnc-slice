#!/bin/sh
# vpnc-script wrapper for openconnect + vpn-slice.
#
# Consumes optional leading directives (baked in by the connect script), then
# execs vpn-slice with the remaining args. sudo strips the connect script's
# environment, so all wrapper config arrives as these directive ARGS -- never via
# env. openconnect invokes this with reason=... and the CISCO_*/INTERNAL_IP4_* env
# vars set; those pass through to vpn-slice unchanged via exec.
#
#   usage: vpnc-slice [directives...] <vpn-slice-path> [vpn-slice args...]
#
# Directives (each acts only once openconnect has populated the environment):
#   --dump-env FILE             dump the server-advertised environment to FILE
#   --write-dns FILE            write the VPN's first pushed DNS server to FILE
#   --proxy NAMES PORT PIDFILE  DNS-driven auto-routing: for each name in NAMES
#                               (comma-separated; the token @server expands to the
#                               server-advertised domains CISCO_SPLIT_DNS /
#                               CISCO_DEF_DOMAIN) write /etc/resolver/<name> pointing
#                               at 127.0.0.1:PORT and start src/dnsroute.py, so those
#                               names resolve via the VPN's DNS and each answered IP
#                               gets a host route through the tunnel. The gateway's
#                               own IP ($VPNGATEWAY) is excluded from routing (it
#                               carries the tunnel itself). Resolver files carry an
#                               "# openconnect-auto-sso" marker so the connect
#                               script's startup sweep can remove stragglers. Torn
#                               down on disconnect (kill PIDFILE + remove the files).
set -eu

# OC_VPNC_SLICE_TEST=1 is a SOURCING-only seam for the test harness (it skips the directive
# loop + exec so sourcing has no side effects). If it leaks into a real EXECUTED run -- this
# wrapper is the root vpnc-script under openconnect -- the routes/DNS would silently never be
# set up. Refuse LOUDLY here, BEFORE sourcing. openconnect always invokes us by our real path
# ($PROJ/bin/vpnc-slice, basename vpnc-slice, no renamed-symlink path); a `.`-source leaves $0
# as the caller's ("sh" under the harness), so the seam is unaffected. (finding 7/10)
if [ "${OC_VPNC_SLICE_TEST:-}" = 1 ]; then
    case ${0##*/} in
        vpnc-slice)
            echo "error: OC_VPNC_SLICE_TEST=1 is set but vpnc-slice is being EXECUTED, not" >&2
            echo "       sourced by the test harness -- refusing to silently no-op. Unset it." >&2
            exit 1 ;;
    esac
fi

# This wrapper always runs as ROOT in production (the vpnc-script under sudo openconnect).
# $PROJ (two dirs up from $0) locates lib/common.sh + the venv; $RESOLVER_DIR is where the
# macOS scoped-resolver files live. These carry test-only overrides (OC_PROJ / RESOLVER_DIR /
# NC_BIN) so the functions can be unit-tested when sourced as the non-root user -- but we
# IGNORE them when running as root, so nothing on the privileged path (root-sourced
# common.sh, root-run dnsroute.py, root-written resolver files, the netcat probe) can be
# redirected by a leaked env var, independent of any sudoers env_keep. (Sudo also strips the
# env; this is defense in depth.) NC_BIN is forced BEFORE sourcing common.sh so its
# `${NC_BIN:-...}` keeps the pinned value -- nothing on the root path calls server_reachable
# today, but pinning it keeps a future root caller (or an env_keep) off an attacker's binary.
if [ "$(id -u)" = 0 ]; then
    PROJ=$(cd "$(dirname "$0")/.." && pwd)
    RESOLVER_DIR=/etc/resolver
    NC_BIN=/usr/bin/nc
else
    PROJ="${OC_PROJ:-$(cd "$(dirname "$0")/.." && pwd)}"
    RESOLVER_DIR="${RESOLVER_DIR:-/etc/resolver}"
fi
. "$PROJ/lib/common.sh"   # RESOLVER_MARKER (shared with the connect script's sweep)

# Remove the /etc/resolver files that are OURS (marker) AND for THIS proxy's port
# ($_port). Port-scoping means tearing down one tunnel never deletes another
# tunnel's resolver files (a second tunnel necessarily uses a different port).
#
# With no argument: removes ALL our-port files (teardown / no-proxy paths). With a
# space-padded " d1 d2 " keep-list ($1): removes only our-port files whose domain is
# NOT in it -- used on the success path to drop domains a reconnect no longer routes,
# without disturbing (and momentarily un-resolving) the ones we just (re)wrote.
_sweep_our_resolvers() {
    _keep=${1:-}
    for _rf in "$RESOLVER_DIR"/*; do
        [ -f "$_rf" ] || continue
        grep -qxF -- "$RESOLVER_MARKER" "$_rf" 2>/dev/null || continue
        grep -qxF -- "port $_port" "$_rf" 2>/dev/null || continue
        if [ -n "$_keep" ]; then
            case "$_keep" in *" ${_rf##*/} "*) continue ;; esac  # still current -- keep
        fi
        rm -f "$_rf" 2>/dev/null || true
    done
}

# Build $_domains (space-separated) from $_names (comma list). @server expands to the
# SERVER-pushed domains (CISCO_SPLIT_DNS) -- untrusted -- so reject any that isn't a
# plain DNS label before it becomes an /etc/resolver/<name> path written as root.
_proxy_domains() {
    _domains=""
    _oldifs=$IFS; IFS=,
    for _n in $_names; do
        if [ "$_n" = "@server" ]; then
            for _s in ${CISCO_SPLIT_DNS:-${CISCO_DEF_DOMAIN:-}}; do
                [ -n "$_s" ] || continue
                case "$_s" in
                    *[!A-Za-z0-9._-]*|*..*|.*|-*)
                        echo ">> ignoring unsafe server-pushed domain: $_s" >&2 ;;
                    *) _domains="$_domains $_s" ;;
                esac
            done
        else
            [ -n "$_n" ] && _domains="$_domains $_n"
        fi
    done
    IFS=$_oldifs
}

# Proxy state file (per-port path chosen by the connect script): line 1 = dnsroute PID,
# line 2 = owning openconnect PID (VPNPID). _proxy_pid reads line 1; _proxy_owner reads
# line 2. _is_dnsroute confirms a PID is really OUR dnsroute before we signal it as root
# -- matched on the FULL "$PROJ/src/dnsroute.py" argv (not a bare "dnsroute.py" substring
# an unrelated process could carry), guarding against PID reuse.
_proxy_pid()   { [ -f "$_pidfile" ] && sed -n 1p "$_pidfile" 2>/dev/null || true; }
_proxy_owner() { [ -f "$_pidfile" ] && sed -n 2p "$_pidfile" 2>/dev/null || true; }
_is_dnsroute() { [ -n "${1:-}" ] && ps -p "$1" -o command= 2>/dev/null | grep -qF -- "$PROJ/src/dnsroute.py"; }

# Ownership invariant, gating EVERY proxy-state mutation (reclaim / disconnect teardown):
# may we kill/rm/sweep this proxy's state? True when it is ours (owner == our VPNPID --
# openconnect keeps the same PID across an in-process reconnect, so this reclaims our own
# old proxy), when no owner is recorded, or when the recorded owner is NOT a live
# openconnect (it died, or its PID was reused by something else). False ONLY when a live
# DIFFERENT openconnect still owns this port: we must never touch its proxy, its pidfile,
# or its /etc/resolver files. `ps -o comm=` works cross-user (unlike kill -0 on a root PID).
_may_touch_proxy() {
    _owner=$(_proxy_owner)
    [ -z "$_owner" ] && return 0                                   # no owner recorded
    [ "$_owner" = "${VPNPID:-}" ] && return 0                      # our own (incl. in-process reconnect)
    # Is the recorded owner a LIVE openconnect? Compare the process's BASENAME to
    # "openconnect" EXACTLY -- a substring grep would also match a reused PID now belonging
    # to e.g. an "openconnect-sso"/"openconnect-gui" process (whose path contains the
    # substring), wrongly reading a dead record as a live tunnel and refusing to reclaim /
    # tear down stale state. `ps -o comm=` works cross-user (unlike kill -0 on a root PID).
    _comm=$(ps -p "$_owner" -o comm= 2>/dev/null)
    [ "${_comm##*/}" = openconnect ] && return 1                   # a live DIFFERENT tunnel
    return 0                                                       # owner dead / reused -> reclaimable
}

# Bring up the DNS-routing proxy on connect|reconnect (uses $_names/$_port/$_pidfile).
# Guard clauses keep it flat; always returns 0 (never abort the vpnc-script pass).
_proxy_connect() {
    # Replace a previous proxy on this port ONLY when the ownership invariant permits it:
    # our own from an in-process reconnect (owner == VPNPID), OR an orphan a crashed
    # predecessor left holding it (owner dead/empty/reused -- its watchdog may never have
    # fired if the utun name got reused). Verify the recorded PID is really our dnsroute
    # (not a reused PID), kill it, and WAIT for it to exit so the port frees -- a straight
    # kill-then-bind races EADDRINUSE. If a live DIFFERENT openconnect owns this port we
    # leave its proxy alone and just try to bind: our bind EADDRINUSEs -> the benign
    # warn-only failed-bind path below.
    _old=$(_proxy_pid)
    if _may_touch_proxy && _is_dnsroute "$_old"; then
        kill "$_old" 2>/dev/null || true
        _i=0
        while kill -0 "$_old" 2>/dev/null && [ "$_i" -lt 30 ]; do
            sleep 0.1; _i=$((_i + 1))
        done
    fi
    _proxy_domains
    # NOTE: do NOT sweep resolver files up front. On a normal reconnect the old files
    # (same marker+port) stay valid across the brief kill/rebind gap, so lookups fail
    # CLOSED (retry into the VPN once the new proxy binds the same port) instead of
    # falling through to the default resolver -- which would leak a split-brain name
    # out the default interface. We sweep ONLY when we won't have a working proxy.

    # These are unset only if the server pushed no IPv4 DNS / no tun device; guard
    # them (bare refs abort under set -u) and skip DNS-routing rather than crash.
    # No proxy is coming up on these branches. Sweep our OWN now-stale port files (so routed
    # domains degrade to default DNS rather than black-holing) -- but ONLY when the ownership
    # invariant permits: never delete a live DIFFERENT same-port tunnel's /etc/resolver files
    # (finding 14). _may_touch_proxy in an `if` keeps set -e happy on its false branch.
    _up=${INTERNAL_IP4_DNS:-}; _dev=${TUNDEV:-}
    if [ -z "$_up" ] || [ -z "$_dev" ]; then
        if _may_touch_proxy; then _sweep_our_resolvers; fi
        echo ">> no VPN DNS/tun device pushed; DNS-routing disabled for:$_domains" >&2
        return 0
    fi
    if [ -z "$_domains" ]; then
        if _may_touch_proxy; then _sweep_our_resolvers; fi
        echo ">> no domains to DNS-route (@server advertised none); proxy not started" >&2
        return 0
    fi

    # Start the proxy and wait for its readiness signal (both sockets bound) before
    # pointing /etc/resolver at it -- "process still alive" can't tell bound from
    # still-importing. --exclude keeps the VPN gateway's own IP off the tunnel.
    _ready="$_pidfile.ready"; rm -f "$_ready" 2>/dev/null || true
    # Have the proxy watch the owning openconnect (VPNPID) so an orphan self-reaps ~1s
    # after its owner dies. Pass it only when openconnect actually set VPNPID; it's a
    # numeric PID, so the unquoted expansion word-splits into two args (or none) safely.
    _watch=""
    [ -n "${VPNPID:-}" ] && _watch="--watch-pid $VPNPID"
    nohup "$PROJ/.venv/bin/python" "$PROJ/src/dnsroute.py" \
        --upstream "$_up" --dev "$_dev" --port "$_port" \
        --exclude "${VPNGATEWAY:-}" --ready-file "$_ready" $_watch \
        >/dev/null 2>&1 &
    _pid=$!
    _i=0
    while [ ! -f "$_ready" ] && kill -0 "$_pid" 2>/dev/null && [ "$_i" -lt 50 ]; do
        sleep 0.1; _i=$((_i + 1))
    done
    if [ ! -f "$_ready" ]; then
        # Kill ONLY the proxy WE just spawned ($_pid) -- it is ours and failed to signal
        # ready. Then, IF the ownership invariant permits (our own dead proxy from an
        # in-process reconnect, or an orphan -- NOT a live DIFFERENT tunnel that won the
        # bind), clear our now-dead-port pidfile + /etc/resolver files so routed domains
        # degrade to default DNS instead of black-holing at a port with nothing listening.
        # If a live winner owns the port, leave its pidfile, .ready, and resolver files
        # intact -- our bind simply lost with EADDRINUSE (finding 14).
        kill "$_pid" 2>/dev/null || true
        if _may_touch_proxy; then
            rm -f "$_pidfile" 2>/dev/null || true
            _sweep_our_resolvers
        fi
        echo "WARNING: DNS-routing proxy failed to bind 127.0.0.1:$_port" \
             "(port busy, invalid, or dnspython missing); DNS-routing disabled." >&2
        return 0
    fi
    # Record the dnsroute PID (line 1) and the owning openconnect PID (line 2, VPNPID) so a
    # later run can reclaim this proxy or detect that this tunnel is still live. Guard the
    # write (|| true): a failed write must not abort the pass.
    printf '%s\n%s\n' "$_pid" "${VPNPID:-}" > "$_pidfile" 2>/dev/null || true
    [ -d "$RESOLVER_DIR" ] || mkdir -p "$RESOLVER_DIR" 2>/dev/null || true
    for _d in $_domains; do
        # Marker + port tag the file as ours for this proxy.
        printf '%s\nnameserver 127.0.0.1\nport %s\n' "$RESOLVER_MARKER" "$_port" \
            > "$RESOLVER_DIR/$_d" 2>/dev/null || true
    done
    # Drop our-port resolver files for domains no longer in the set (e.g. a reconnect
    # where @server advertised fewer domains than last time). The current domains were
    # just (re)written above, so passing them as the keep-list means retained names
    # never lose their file -- only the dropped ones are removed, no resolution gap.
    _sweep_our_resolvers " $_domains "
    echo ">> DNS-routing via VPN for:$_domains (127.0.0.1:$_port)" >&2
    rm -f "$_ready" 2>/dev/null || true
}

# The test harness sources this file to exercise the functions above in isolation;
# OC_VPNC_SLICE_TEST=1 skips the directive loop + exec so sourcing has no side effects.
# Guard the body with `if` rather than a top-level `return` (invalid when the script is
# executed, and a swallowed error under set -e).
if [ "${OC_VPNC_SLICE_TEST:-}" != 1 ]; then
while :; do
    case "${1:-}" in
        --dump-env)   # dump the full server-advertised environment to a file
            _f="$2"; shift 2
            case "${reason:-}" in connect|reconnect) env | sort > "$_f" 2>/dev/null || true ;; esac ;;
        --write-dns)  # write the VPN's first pushed DNS server to a file
            _f="$2"; shift 2
            # ${INTERNAL_IP4_DNS:-} guard: the var is optional (a server may push no
            # IPv4 DNS), and a bare ${INTERNAL_IP4_DNS%% *} would abort under set -u.
            case "${reason:-}" in
                connect|reconnect)
                    _d1=${INTERNAL_IP4_DNS:-}
                    [ -n "$_d1" ] && printf '%s\n' "${_d1%% *}" > "$_f" 2>/dev/null || true ;;
            esac ;;
        --proxy)      # DNS-driven auto-routing via the loopback dnsroute proxy
            _names="$2"; _port="$3"; _pidfile="$4"; shift 4
            case "${reason:-}" in
                connect|reconnect) _proxy_connect ;;
                disconnect)
                    # Tear down ONLY if the ownership invariant permits: this proxy is
                    # ours (owner == our VPNPID -- the openconnect running this very pass),
                    # unowned, or owned by a dead/reused PID. If a live DIFFERENT
                    # openconnect owns this port, do NOTHING -- leaving its proxy, pidfile,
                    # and /etc/resolver files intact so one tunnel's disconnect never yanks
                    # another same-port tunnel's DNS (finding 14).
                    if _may_touch_proxy; then
                        # Kill ONLY the dnsroute (line 1) -- never line 2's openconnect PID,
                        # which is mid-teardown running this very pass. Verify it's ours first.
                        _old=$(_proxy_pid)
                        _is_dnsroute "$_old" && kill "$_old" 2>/dev/null || true
                        rm -f "$_pidfile" "$_pidfile.ready" 2>/dev/null || true
                        # Remove our resolver files by marker+port (see _sweep_our_resolvers)
                        # rather than re-deriving domain names from a server env that may
                        # differ/be absent now -- and scoped to this port so a second
                        # tunnel's files are left intact.
                        _sweep_our_resolvers
                    fi ;;
            esac ;;
        *) break ;;
    esac
done

vpn_slice="$1"; shift
exec "$vpn_slice" "$@"
fi

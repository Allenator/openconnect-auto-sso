#!/bin/sh
# vpnc-script wrapper for openconnect + vpn-slice.
#
# Consumes optional leading directives (baked in by the connect script), then
# execs vpn-slice with the remaining args. sudo strips the connect script's
# environment, so all wrapper config arrives as these directive ARGS -- never via
# env. openconnect invokes this with reason=... and the CISCO_*/INTERNAL_IP4_* env
# vars set; those pass through to vpn-slice unchanged via exec.
#
#   usage: vpnc-slice [directives...] <vpn-slice-path> [vpn-slice args...]
#
# Directives (each acts only once openconnect has populated the environment):
#   --dump-env FILE             dump the server-advertised environment to FILE
#   --write-dns FILE            write the VPN's first pushed DNS server to FILE
#   --proxy NAMES PORT PIDFILE  DNS-driven auto-routing: for each name in NAMES
#                               (comma-separated; the token @server expands to the
#                               server-advertised domains CISCO_SPLIT_DNS /
#                               CISCO_DEF_DOMAIN) write /etc/resolver/<name> pointing
#                               at 127.0.0.1:PORT and start src/dnsroute.py, so those
#                               names resolve via the VPN's DNS and each answered IP
#                               gets a host route through the tunnel. The gateway's
#                               own IP ($VPNGATEWAY) is excluded from routing (it
#                               carries the tunnel itself). Resolver files carry an
#                               "# openconnect-auto-sso" marker so the connect
#                               script's startup sweep can remove stragglers. Torn
#                               down on disconnect (kill PIDFILE + remove the files).
set -eu

# The wrapper lives at $PROJ/bin/vpnc-slice, so $PROJ is two dirs up from $0.
PROJ=$(cd "$(dirname "$0")/.." && pwd)
. "$PROJ/lib/common.sh"   # RESOLVER_MARKER (shared with the connect script's sweep)

# Remove the /etc/resolver files that are OURS (marker) AND for THIS proxy's port
# ($_port). Port-scoping means tearing down one tunnel never deletes another
# tunnel's resolver files (a second tunnel necessarily uses a different port).
_sweep_our_resolvers() {
    for _rf in /etc/resolver/*; do
        [ -f "$_rf" ] || continue
        grep -qxF -- "$RESOLVER_MARKER" "$_rf" 2>/dev/null || continue
        grep -qxF "port $_port" "$_rf" 2>/dev/null || continue
        rm -f "$_rf" 2>/dev/null || true
    done
}

while :; do
    case "${1:-}" in
        --dump-env)   # dump the full server-advertised environment to a file
            _f="$2"; shift 2
            case "${reason:-}" in connect|reconnect) env | sort > "$_f" 2>/dev/null || true ;; esac ;;
        --write-dns)  # write the VPN's first pushed DNS server to a file
            _f="$2"; shift 2
            # ${INTERNAL_IP4_DNS:-} guard: the var is optional (a server may push no
            # IPv4 DNS), and a bare ${INTERNAL_IP4_DNS%% *} would abort under set -u.
            case "${reason:-}" in
                connect|reconnect)
                    _d1=${INTERNAL_IP4_DNS:-}
                    [ -n "$_d1" ] && printf '%s\n' "${_d1%% *}" > "$_f" 2>/dev/null || true ;;
            esac ;;
        --proxy)      # DNS-driven auto-routing via the loopback dnsroute proxy
            _names="$2"; _port="$3"; _pidfile="$4"; shift 4
            # Expand @server -> the server-advertised domains; build a space-
            # separated list of the concrete names to resolve via the VPN.
            # Build the concrete domain list. Names from $_names (the config) were
            # already validated by loadconfig, but @server expands to domains the
            # SERVER pushes (CISCO_SPLIT_DNS) -- untrusted input that becomes an
            # /etc/resolver/<name> path written as root. Reject any that isn't a
            # plain DNS name so a hostile server can't traverse out of /etc/resolver.
            _domains=""
            _oldifs=$IFS; IFS=,
            for _n in $_names; do
                if [ "$_n" = "@server" ]; then
                    for _s in ${CISCO_SPLIT_DNS:-${CISCO_DEF_DOMAIN:-}}; do
                        [ -n "$_s" ] || continue
                        case "$_s" in
                            *[!A-Za-z0-9.-]*|*..*|.*|-*)
                                echo ">> ignoring unsafe server-pushed domain: $_s" >&2 ;;
                            *) _domains="$_domains $_s" ;;
                        esac
                    done
                else
                    [ -n "$_n" ] && _domains="$_domains $_n"
                fi
            done
            IFS=$_oldifs
            case "${reason:-}" in
                connect|reconnect)
                    # Kill any previous proxy and WAIT for it to release the port
                    # before rebinding -- a straight kill-then-bind races EADDRINUSE
                    # and the new proxy would die silently (SO_REUSEADDR doesn't
                    # reliably cover a still-open UDP bind).
                    if [ -f "$_pidfile" ]; then
                        _old=$(cat "$_pidfile" 2>/dev/null || true)
                        [ -n "$_old" ] && kill "$_old" 2>/dev/null || true
                        _i=0
                        while [ -n "$_old" ] && kill -0 "$_old" 2>/dev/null && [ "$_i" -lt 30 ]; do
                            sleep 0.1; _i=$((_i + 1))
                        done
                    fi
                    # Clean slate: drop our (this-port) resolver files up front. They
                    # are rewritten below ONLY if a new proxy actually binds, so a
                    # skipped or failed start never leaves files aimed at a dead port.
                    _sweep_our_resolvers
                    # These are only unset if the server pushed no IPv4 DNS / no tun
                    # device; guard them (bare refs would abort under set -u) and skip
                    # DNS-routing rather than crash the whole vpnc-script pass.
                    _up=${INTERNAL_IP4_DNS:-}; _dev=${TUNDEV:-}
                    if [ -z "$_up" ] || [ -z "$_dev" ]; then
                        echo ">> no VPN DNS/tun device pushed; DNS-routing disabled for:$_domains" >&2
                    elif [ -z "$_domains" ]; then
                        echo ">> no domains to DNS-route (@server advertised none); proxy not started" >&2
                    else
                        # Start the proxy and wait for its readiness signal (both
                        # sockets bound) before pointing /etc/resolver at it. A mere
                        # "process still alive" check can't tell bound from still-
                        # importing, so it could wire DNS to a not-yet/never-bound port.
                        # --exclude keeps the VPN gateway's own IP off the tunnel.
                        _ready="$_pidfile.ready"; rm -f "$_ready" 2>/dev/null || true
                        nohup "$PROJ/.venv/bin/python" "$PROJ/src/dnsroute.py" \
                            --upstream "$_up" --dev "$_dev" --port "$_port" \
                            --exclude "${VPNGATEWAY:-}" --ready-file "$_ready" \
                            >/dev/null 2>&1 &
                        _pid=$!
                        _i=0
                        while [ ! -f "$_ready" ] && kill -0 "$_pid" 2>/dev/null && [ "$_i" -lt 50 ]; do
                            sleep 0.1; _i=$((_i + 1))
                        done
                        if [ -f "$_ready" ]; then
                            # Guard the pidfile write (|| true): a failed write must not
                            # abort the whole vpnc-script pass before it execs vpn-slice.
                            echo "$_pid" > "$_pidfile" 2>/dev/null || true
                            [ -d /etc/resolver ] || mkdir -p /etc/resolver 2>/dev/null || true
                            for _d in $_domains; do
                                # Marker + port tag the file as ours for this proxy.
                                printf '%s\nnameserver 127.0.0.1\nport %s\n' "$RESOLVER_MARKER" "$_port" \
                                    > "/etc/resolver/$_d" 2>/dev/null || true
                            done
                            echo ">> DNS-routing via VPN for:$_domains (127.0.0.1:$_port)" >&2
                        else
                            kill "$_pid" 2>/dev/null || true
                            rm -f "$_pidfile" 2>/dev/null || true
                            echo "WARNING: DNS-routing proxy failed to bind 127.0.0.1:$_port" \
                                 "(port busy, invalid, or dnspython missing); DNS-routing disabled." >&2
                        fi
                        rm -f "$_ready" 2>/dev/null || true
                    fi ;;
                disconnect)
                    [ -f "$_pidfile" ] && kill "$(cat "$_pidfile")" 2>/dev/null || true
                    rm -f "$_pidfile" 2>/dev/null || true
                    # Remove our resolver files by marker+port (see _sweep_our_resolvers)
                    # rather than re-deriving domain names from a server env that may
                    # differ/be absent now -- and scoped to this port so a second
                    # tunnel's files are left intact.
                    _sweep_our_resolvers ;;
            esac ;;
        *) break ;;
    esac
done

# Record openconnect's own PID (it exports VPNPID to the vpnc-script) to a root-owned
# file so the privileged vpn-teardown helper can cleanly stop the tunnel on
# logout/uninstall. Runs for every reason, independent of the directives above.
case "${reason:-}" in
    connect|reconnect)
        [ -n "${VPNPID:-}" ] && printf '%s\n' "$VPNPID" > "$VPNPID_FILE" 2>/dev/null || true ;;
    disconnect)
        rm -f "$VPNPID_FILE" 2>/dev/null || true ;;
esac

vpn_slice="$1"; shift
exec "$vpn_slice" "$@"
